do
    local remotes = {}
    local tCons = {}
    local warning
    Tab.Server:AddToggle({Name = "Lag Server", Default = false, Callback = function(c)
        if not warning then warning = true; gui.Notify("Ping will NOT recover, rejoin to fix"); return end
        if c then
            for _, v in pairs(plrs:GetPlayers()) do
                table.insert(remotes, v.Backpack:FindFirstChild("reload", true))
                if v.Character then table.insert(remotes, v.Character:FindFirstChild("reload", true)) end
            end
            local ps = #remotes * 700
            for i = 1, #remotes do
                local v = remotes[i]
                table.insert(tCons, runServ.PreRender:Connect(function()
                    coroutine.wrap(function() for _ = 1, ps do coroutine.wrap(v.FireServer)(v) end end)()
                end))
            end
        else
            coroutine.wrap(TeleportService.TeleportToPlaceInstance)(TeleportService, game.PlaceId, game.JobId)
            for _, v in pairs(tCons) do v:Disconnect() end
            table.clear(tCons)
            table.clear(remotes)
        end
    end})
end

do
    local cache = {}
    local fp = function(og, new) pcall(function() og.Parent = new end) end
    Tab.Server:AddToggle({Name = "Lag Other Players", Default = false, Callback = function(c)
        if c then
            if lplr.Team ~= Teams.Zombie then itemFuncs.Virus() end
            gui.Notify("disable to release buffer")
            repeat
                buyItem:InvokeServer("Knife")
                for _, v in pairs(lplr.Backpack:GetChildren()) do
                    if v.Name == "Knife" and not table.find(cache, v) then
                        table.insert(cache, v)
                        coroutine.wrap(fp)(v, lplr.Character)
                    end
                end
                task.wait()
            until not c
            for _, v in pairs(cache) do coroutine.wrap(fp)(v, workspace) end
            for _, v in pairs(cache) do coroutine.wrap(fp)(v, nil) end
            table.clear(cache)
        end
    end})
end

