local itemFuncs = {Virus = emptyFunc, Cure = emptyFunc}
do
    local transTbl = {Virus = Teams.Zombie, Cure = Teams.Human}
    local room = workspace.Lab.Machines["Virus Room"]
    local prompt = room.Button.Button.Trigger
    itemFuncs.Virus = function()
        if not room.Smoke:FindFirstChildWhichIsA("TouchTransmitter") then
            repeat
                pcall(function() lplr.Character.PrimaryPart.CFrame = prompt.Parent.CFrame end)
                fireproximityprompt(prompt)
                task.wait()
            until room.Smoke:FindFirstChildWhichIsA("TouchTransmitter")
        end
        for i = 0, 1 do firetouchinterest(lplr.Character.PrimaryPart, room.Smoke, i) end
        local timeout = tick() + .5
        repeat task.wait() until lplr.Character.Ragdoll.Value or (tick() >= timeout)
        if tick() >= timeout then return itemFuncs.Virus() end
    end
    itemFuncs.Cure = function()
        if #plrs:GetPlayers() <= 1 then lplr:Kick() end
        TeleportService:Teleport(game.PlaceId)
    end
    for i, v in pairs(itemFuncs) do Tab.Player:AddButton({Name = "Become " .. transTbl[i].Name, Callback = v}) end
end

local changeTeam
do
    local transTbl = {Zombie = itemFuncs.Virus, Human = itemFuncs.Cure}
    changeTeam = function(t) return transTbl[t.Name]() end
end

local checkTeam = function(v)
    if v:IsA("Team") and lplr.Team ~= v then changeTeam(v) repeat task.wait() until lplr.Team == v end
end

local buyItem = rStor:WaitForChild("BuyItem")
local remote, gun = nil, nil
local findRemote = function()
    if not remote or not remote.Parent or not gun or not gun.Parent then
        gun = find.Gun(true)
        if not gun then return end
        remote = gun:FindFirstChild("InflictTarget", true)
    end
end

local shootPlr = function(v, dmg)
    local hum = (v.ClassName == "Player" and v.Character and v.Character:FindFirstChild("Humanoid")) or v:FindFirstChild("Humanoid")
    local part = (hum and hum.Parent and hum.Parent:FindFirstChildWhichIsA("BasePart"))
    if hum and part and remote then
        coroutine.wrap(remote.FireServer)(remote, hum, part, (dmg or hum.MaxHealth), Vector3.zero, 2, 0, false)
    end
end

local shootTillDead = shootPlr

do
    local isAlive = function(p, await)
        local c = (p.ClassName == "Player" and p.Character) or p
        if c then return (await and c.WaitForChild or c.FindFirstChild)(c, "Head") end
    end
    local loopTbl = {}
    local hookChr = function(p)
        if p.ClassName == "Player" and p.Team == lplr.Team then return end
        if isAlive(p, true) then table.insert(loopTbl, p) end
    end
    local tCons = {}
    local hookPlr = function(p)
        if p.Character then coroutine.wrap(hookChr)(p) end
        table.insert(tCons, p.CharacterAdded:Connect(function() hookChr(p) end))
    end
    local transTbl = {Zombie = "Humans", Human = "Zombies", Zombies = "NPCs"}
    local teamScan = Teams:GetTeams()
    table.insert(teamScan, workspace:WaitForChild("Zombies"))
    for _, team in pairs(teamScan) do
        if team and transTbl[team.Name] then
            local tName = transTbl[team.Name]
            local isTeam = (team.ClassName == "Team")
            Tab.Server:AddButton({Name = "Kill " .. tName, Callback = function()
                checkTeam(team)
                findRemote()
                for _, v in pairs((isTeam and plrs:GetPlayers()) or team:GetChildren()) do
                    if isAlive(v) and (not isTeam or (lplr ~= v and v.Team ~= lplr.Team)) then shootTillDead(v) end
                end
            end})
            Tab.Server:AddButton({Name = "God " .. tName, Callback = function()
                checkTeam(team)
                findRemote()
                for _, v in pairs((isTeam and plrs:GetPlayers()) or team:GetChildren()) do
                    if isAlive(v) and (not isTeam or (lplr ~= v and v.Team ~= lplr.Team)) then shootPlr(v, tonumber("nan")) end
                end
                gui.Notify("made " .. tName .. " immune")
            end})
        end
    end
end

