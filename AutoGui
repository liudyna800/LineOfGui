-- SLIDER
-- =============================================
function AutoGui:AddSlider(section, text, min, max, default, callback, params)
    params = params or {}
    min = min or 0
    max = max or 100
    default = _default(default, min)
    local value = math.clamp(default, min, max)

    local container = Instance.new("Frame")
    container.Name = "Slider"
    container.Parent = section.frame
    container.Size = UDim2.new(1, 0, 0, _default(params.Height, 50))
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.ZIndex = 1

    local sliderLabel = Instance.new("TextLabel")
    sliderLabel.Name = "SliderLabel"
    sliderLabel.Parent = container
    sliderLabel.Size = UDim2.new(1, 0, 0, 16)
    sliderLabel.BackgroundTransparency = 1
    sliderLabel.Text = text .. " (" .. value .. ")"
    sliderLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
    sliderLabel.TextSize = 11
    sliderLabel.Font = Enum.Font.Gotham
    sliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    sliderLabel.ZIndex = 1

    local sliderBg = Instance.new("Frame")
    sliderBg.Name = "SliderBg"
    sliderBg.Parent = container
    sliderBg.Position = UDim2.new(0, 0, 0, 20)
    sliderBg.Size = UDim2.new(1, 0, 0, 6)
    sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    sliderBg.BorderSizePixel = 0
    sliderBg.ZIndex = 1
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

    local sliderFill = Instance.new("Frame")
    sliderFill.Name = "SliderFill"
    sliderFill.Parent = sliderBg
    sliderFill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(80, 150, 255)
    sliderFill.BorderSizePixel = 0
    sliderFill.ZIndex = 1
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Name = "SliderBtn"
    sliderBtn.Parent = sliderBg
    sliderBtn.Size = UDim2.new(0, 14, 0, 14)
    sliderBtn.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.Text = ""
    sliderBtn.BorderSizePixel = 0
    sliderBtn.ZIndex = 2
    Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(1, 0)

    local dragging = false
    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    local conn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    table.insert(self.Connections, conn)

    local conn2 = UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderAbsPos = sliderBg.AbsolutePosition
            local sliderAbsSize = sliderBg.AbsoluteSize
            local relativeX = math.clamp((mousePos.X - sliderAbsPos.X) / sliderAbsSize.X, 0, 1)
            value = math.floor(min + (max - min) * relativeX + 0.5)
            value = math.clamp(value, min, max)

            sliderFill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            sliderBtn.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
            sliderLabel.Text = text .. " (" .. value .. ")"

            if callback then
                callback(value)
            end
        end
    end)
    table.insert(self.Connections, conn2)

    if callback then
        callback(value)
    end

    return {
        Container = container,
        GetValue = function() return value end,
        SetValue = function(val)
            value = math.clamp(val, min, max)
            sliderFill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            sliderBtn.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
            sliderLabel.Text = text .. " (" .. value .. ")"
            if callback then callback(value) end
        end,
    }
end

-- =============================================
-- DROPDOWN
-- =============================================
function AutoGui:AddDropdown(section, text, options, callback, params)
    params = params or {}
    options = options or {}
    local selected = _default(params.Default, options[1] or "")
    local opened = false
    local dropdownButtons = {}

    local container = Instance.new("Frame")
    container.Name = "Dropdown"
    container.Parent = section.frame
    container.Size = UDim2.new(1, 0, 0, _default(params.Height, 34))
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.ZIndex = 1

    local dropdownBtn = Instance.new("TextButton")
    dropdownBtn.Name = "DropdownBtn"
    dropdownBtn.Parent = container
    dropdownBtn.Text = "  ▼  " .. text .. ": " .. selected
    dropdownBtn.Size = UDim2.new(1, 0, 1, 0)
    dropdownBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    dropdownBtn.TextColor3 = Color3.fromRGB(220, 220, 240)
    dropdownBtn.TextSize = 12
    dropdownBtn.Font = Enum.Font.Gotham
    dropdownBtn.TextXAlignment = Enum.TextXAlignment.Left
    dropdownBtn.BorderSizePixel = 0
    dropdownBtn.ZIndex = 1
    Instance.new("UICorner", dropdownBtn).CornerRadius = UDim.new(0, 6)

    local optionsFrame = Instance.new("Frame")
    optionsFrame.Name = "OptionsFrame"
    optionsFrame.Parent = container
    optionsFrame.Position = UDim2.new(0, 0, 1, 2)
    optionsFrame.Size = UDim2.new(1, 0, 0, 0)
    optionsFrame.AutomaticSize = Enum.AutomaticSize.Y
    optionsFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
    optionsFrame.BorderSizePixel = 0
    optionsFrame.Visible = false
    optionsFrame.ZIndex = 5
    Instance.new("UICorner", optionsFrame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", optionsFrame):Assign({
        Color = Color3.fromRGB(60, 60, 85),
        Thickness = 1,
    })

    local optionsLayout = Instance.new("UIListLayout")
    optionsLayout.Parent = optionsFrame
    optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local optionsPad = Instance.new("UIPadding")
    optionsPad.Parent = optionsFrame
    optionsPad.PaddingLeft = UDim.new(0, 4)
    optionsPad.PaddingRight = UDim.new(0, 4)
    optionsPad.PaddingTop = UDim.new(0, 4)
    optionsPad.PaddingBottom = UDim.new(0, 4)

    -- Track for outside click close
    local dropdownConnection
    local function closeDropdown()
        opened = false
        optionsFrame.Visible = false
        container.Size = UDim2.new(1, 0, 0, 34)
        if dropdownConnection then
            dropdownConnection:Disconnect()
            dropdownConnection = nil
        end
    end

    dropdownBtn.MouseButton1Click:Connect(function()
        opened = not opened
        optionsFrame.Visible = opened
        if opened then
            container.Size = UDim2.new(1, 0, 0, 34 + optionsFrame.AbsoluteSize.Y + 4)
            dropdownConnection = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mousePos = Vector2.new(input.Position.X, input.Position.Y)
                    local optAbsPos = optionsFrame.AbsolutePosition
                    local optAbsSize = optionsFrame.AbsoluteSize
                    if mousePos.X < optAbsPos.X or mousePos.X > optAbsPos.X + optAbsSize.X
                    or mousePos.Y < optAbsPos.Y or mousePos.Y > optAbsPos.Y + optAbsSize.Y then
                        local btnAbsPos = dropdownBtn.AbsolutePosition
                        local btnAbsSize = dropdownBtn.AbsoluteSize
                        if mousePos.X < btnAbsPos.X or mousePos.X > btnAbsPos.X + btnAbsSize.X
                        or mousePos.Y < btnAbsPos.Y or mousePos.Y > btnAbsPos.Y + btnAbsSize.Y then
                            closeDropdown()
                        end
                    end
                end
            end)
        else
            closeDropdown()
        end
    end)

    local function createOption(opt)
        local optBtn = Instance.new("TextButton")
        optBtn.Name = "Option_" .. opt
        optBtn.Parent = optionsFrame
        optBtn.Text = opt
        optBtn.Size = UDim2.new(1, 0, 0, 28)
        optBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
        optBtn.TextColor3 = Color3.fromRGB(200, 200, 220)
        optBtn.TextSize = 11
        optBtn.Font = Enum.Font.Gotham
        optBtn.BorderSizePixel = 0
        optBtn.ZIndex = 6
        Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 4)

        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            dropdownBtn.Text = "  ▼  " .. text .. ": " .. selected
            closeDropdown()
            if callback then
                callback(selected)
            end
        end)

        optBtn.MouseEnter:Connect(function()
            _tween(optBtn, {BackgroundColor3 = Color3.fromRGB(60, 60, 80)}, 0.15)
        end)
        optBtn.MouseLeave:Connect(function()
            _tween(optBtn, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}, 0.15)
        end)

        table.insert(dropdownButtons, optBtn)
    end

    for _, opt in ipairs(options) do
        createOption(opt)
    end

    if callback then
        callback(selected)
    end

    return {
        Container = container,
        GetValue = function() return selected end,
        SetValue = function(val)
            selected = val
            dropdownBtn.Text = "  ▼  " .. text .. ": " .. selected
            if callback then callback(selected) end
        end,
        AddOption = function(opt)
            table.insert(options, opt)
            createOption(opt)
        end,
        RemoveOption = function(opt)
            for i, o in ipairs(options) do
                if o == opt then
                    table.remove(options, i)
                    if selected == opt then
                        selected = options[1] or ""
                        dropdownBtn.Text = "  ▼  " .. text .. ": " .. selected
                    end
                    break
                end
            end
            for _, btn in ipairs(dropdownButtons) do
                if btn.Text == opt then
                    btn:Destroy()
                    table.remove(dropdownButtons, table.find(dropdownButtons, btn))
                    break
                end
            end
        end,
    }
end

