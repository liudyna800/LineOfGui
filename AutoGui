function AutoGui:CreateTab(params)
    params = params or {}
    local tabIdx = #self.Tabs + 1

    -- Tab bar
    if not self.TabBar then
        self.TabBar = Instance.new("Frame")
        self.TabBar.Name = "TabBar"
        self.TabBar.Parent = self.MainFrame
        self.TabBar.Size = UDim2.new(0, 120, 1, -36)
        self.TabBar.Position = UDim2.new(0, 0, 0, 36)
        self.TabBar.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
        self.TabBar.BorderSizePixel = 0
        self.TabBar.ZIndex = 1

        local tabList = Instance.new("UIListLayout")
        tabList.Parent = self.TabBar
        tabList.SortOrder = Enum.SortOrder.LayoutOrder
        tabList.Padding = UDim.new(0, 2)

        local tabPad = Instance.new("UIPadding")
        tabPad.Parent = self.TabBar
        tabPad.PaddingLeft = UDim.new(0, 4)
        tabPad.PaddingRight = UDim.new(0, 4)
        tabPad.PaddingTop = UDim.new(0, 4)

        -- Tab content area
        local TabContent = Instance.new("Frame")
        TabContent.Name = "TabContent"
        TabContent.Parent = self.ContentArea
        TabContent.Size = UDim2.new(1, -124, 1, 0)
        TabContent.Position = UDim2.new(0, 124, 0, 4)
        TabContent.BackgroundTransparency = 1
        TabContent.BorderSizePixel = 0
        TabContent.ZIndex = 1
        self.TabContent = TabContent
    end

    local tabBtn = Instance.new("TextButton")
    tabBtn.Name = "TabBtn_" .. tabIdx
    tabBtn.Parent = self.TabBar
    tabBtn.Text = "  " .. (params.Title or "Tab " .. tabIdx)
    if params.Icon then
        tabBtn.Text = params.Icon .. "  " .. (params.Title or "Tab " .. tabIdx)
    end
    tabBtn.Size = UDim2.new(1, -8, 0, 32)
    tabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
    tabBtn.TextColor3 = Color3.fromRGB(160, 160, 180)
    tabBtn.TextSize = 12
    tabBtn.Font = Enum.Font.Gotham
    tabBtn.TextXAlignment = Enum.TextXAlignment.Left
    tabBtn.BorderSizePixel = 0
    tabBtn.ZIndex = 1
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 6)

    -- Tab page (scrollable)
    local tabPage = Instance.new("ScrollingFrame")
    tabPage.Name = "TabPage_" .. tabIdx
    tabPage.Parent = self.TabContent
    tabPage.Size = UDim2.new(1, 0, 1, -4)
    tabPage.BackgroundTransparency = 1
    tabPage.BorderSizePixel = 0
    tabPage.ScrollBarThickness = 4
    tabPage.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 100)
    tabPage.ScrollingDirection = Enum.ScrollingDirection.Y
    tabPage.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabPage.ZIndex = 1
    tabPage.Visible = (tabIdx == 1)

    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Parent = tabPage
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pageLayout.Padding = UDim.new(0, 8)

    local pagePad = Instance.new("UIPadding")
    pagePad.Parent = tabPage
    pagePad.PaddingLeft = UDim.new(0, 8)
    pagePad.PaddingRight = UDim.new(0, 8)
    pagePad.PaddingTop = UDim.new(0, 6)
    pagePad.PaddingBottom = UDim.new(0, 6)

    local tab = {
        Button = tabBtn,
        Page = tabPage,
        Layout = pageLayout,
        Index = tabIdx,
    }
    table.insert(self.Tabs, tab)

    -- Switch on click
    tabBtn.MouseButton1Click:Connect(function()
        self:ActivateTab(tabIdx)
    end)

    if tabIdx == 1 then
        self:ActivateTab(1)
    end

    return {
        tab = tab,
        window = self,
    }
end

function AutoGui:ActivateTab(idx)
    self.ActiveTab = idx
    for i, tab in ipairs(self.Tabs) do
        tab.Page.Visible = (i == idx)
        if i == idx then
            tab.Button.BackgroundColor3 = Color3.fromRGB(60, 60, 85)
            tab.Button.TextColor3 = Color3.fromRGB(200, 200, 230)
        else
            tab.Button.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
            tab.Button.TextColor3 = Color3.fromRGB(160, 160, 180)
        end
    end
end

