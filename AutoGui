do
    local function AddHighlight(plr)
        if plr.Character and not plr.Character:FindFirstChildWhichIsA("Highlight") then
            local hl = Instance.new("Highlight")
            hl.Adornee = plr.Character
            hl.Parent = plr.Character
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillColor = plr.TeamColor.Color
            hl.OutlineColor = Color3.fromRGB(235,235,235)
            hl.FillTransparency = .3
            return hl
        end
    end
    local function RemoveHighlights(plr)
        local hl = plr.Character and plr.Character:FindFirstChildWhichIsA("Highlight")
        if hl then hl:Destroy() end
    end
    local function ActuallyAddingHighlights(plr)
        local ratlight
        if plr.Character then ratlight = AddHighlight(plr) end
        plr:GetPropertyChangedSignal("TeamColor"):Connect(function()
            if ratlight and ratlight.Parent then ratlight.FillColor = plr.TeamColor.Color end
        end)
    end
    local espEnabled = false
    Tab.Player:AddToggle({Name = "ESP", Default = false, Callback = function(v) espEnabled = v end})
    spawn(function()
        while task.wait(0.1) do
            if espEnabled then
                for _, pl in pairs(plrs:GetPlayers()) do
                    if lplr ~= pl then ActuallyAddingHighlights(pl) end
                end
            else
                for _, pl in pairs(plrs:GetPlayers()) do RemoveHighlights(pl) end
            end
        end
    end)
end

do
