-- =============================================
-- BUTTON
-- =============================================
function AutoGui:AddButton(section, text, callback, params)
    params = params or {}
    local btn = Instance.new("TextButton")
    btn.Name = "Button"
    btn.Parent = section.frame
    btn.Text = text
    btn.Size = UDim2.new(1, 0, 0, _default(params.Height, 34))
    btn.BackgroundColor3 = _default(params.ButtonColor, Color3.fromRGB(60, 60, 90))
    btn.TextColor3 = _default(params.TextColor, Color3.fromRGB(255, 255, 255))
    btn.TextSize = _default(params.TextSize, 13)
    btn.Font = _default(params.Font, Enum.Font.GothamBold)
    btn.BorderSizePixel = 0
    btn.ZIndex = 1
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, _default(params.CornerRadius, 6))

    local origColor = btn.BackgroundColor3
    btn.MouseEnter:Connect(function()
        _tween(btn, {BackgroundColor3 = Color3.fromRGB(
            math.min(origColor.R * 255 + 25, 255),
            math.min(origColor.G * 255 + 25, 255),
            math.min(origColor.B * 255 + 25, 255)
        )}, 0.15)
    end)
    btn.MouseLeave:Connect(function()
        _tween(btn, {BackgroundColor3 = origColor}, 0.15)
    end)
    if callback then
        btn.MouseButton1Click:Connect(callback)
    end
    return btn
end

-- =============================================
-- TOGGLE
-- =============================================
function AutoGui:AddToggle(section, text, callback, params)
    params = params or {}
    local defaultValue = _default(params.Default, false)
    local enabled = defaultValue

    local container = Instance.new("Frame")
    container.Name = "Toggle"
    container.Parent = section.frame
    container.Size = UDim2.new(1, 0, 0, _default(params.Height, 32))
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.ZIndex = 1

    local toggleLabel = Instance.new("TextLabel")
    toggleLabel.Name = "ToggleLabel"
    toggleLabel.Parent = container
    toggleLabel.Position = UDim2.new(0, 0, 0, 0)
    toggleLabel.Size = UDim2.new(1, -50, 1, 0)
    toggleLabel.BackgroundTransparency = 1
    toggleLabel.Text = text
    toggleLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
    toggleLabel.TextSize = 12
    toggleLabel.Font = Enum.Font.Gotham
    toggleLabel.TextXAlignment = Enum.TextXAlignment.Left
    toggleLabel.ZIndex = 1

    local toggleFrame = Instance.new("Frame")
    toggleFrame.Name = "ToggleFrame"
    toggleFrame.Parent = container
    toggleFrame.Size = UDim2.new(0, 40, 0, 20)
    toggleFrame.Position = UDim2.new(1, -44, 0.5, -10)
    toggleFrame.BackgroundColor3 = defaultValue and Color3.fromRGB(80, 160, 80) or Color3.fromRGB(50, 50, 60)
    toggleFrame.BorderSizePixel = 0
    toggleFrame.ZIndex = 1
    Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(1, 0)

    local toggleDot = Instance.new("Frame")
    toggleDot.Name = "ToggleDot"
    toggleDot.Parent = toggleFrame
    toggleDot.Size = UDim2.new(0, 16, 0, 16)
    toggleDot.Position = defaultValue and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    toggleDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toggleDot.BorderSizePixel = 0
    toggleDot.ZIndex = 2
    Instance.new("UICorner", toggleDot).CornerRadius = UDim.new(1, 0)

    local function updateToggle()
        enabled = not enabled
        local targetColor = enabled and Color3.fromRGB(80, 160, 80) or Color3.fromRGB(50, 50, 60)
        local targetPos = enabled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        _tween(toggleFrame, {BackgroundColor3 = targetColor}, 0.2)
        _tween(toggleDot, {Position = targetPos}, 0.2)
        if callback then
            callback(enabled)
        end
    end

    container.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateToggle()
        end
    end)

    if defaultValue and callback then
        task.spawn(function() callback(true) end)
    end

    return {
        Container = container,
        ToggleFrame = toggleFrame,
        ToggleDot = toggleDot,
        GetState = function() return enabled end,
        SetState = function(state)
            if state ~= enabled then
                enabled = state
                toggleFrame.BackgroundColor3 = enabled and Color3.fromRGB(80, 160, 80) or Color3.fromRGB(50, 50, 60)
                toggleDot.Position = enabled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                if callback then callback(enabled) end
            end
        end,
    }
end

