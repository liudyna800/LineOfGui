local findRemote = function() if not remote or not remote.Parent or not gun or not gun.Parent then gun = find.Gun(true) if not gun then return end remote = gun:FindFirstChild("InflictTarget", true) end end
local shootPlr = function(v, dmg)
    local hum = (v.ClassName == "Player" and v.Character and v.Character:FindFirstChild("Humanoid")) or v:FindFirstChild("Humanoid")
    local part = (hum and hum.Parent and hum.Parent:FindFirstChildWhichIsA("BasePart"))
    if hum and part and remote then coroutine.wrap(remote.FireServer)(remote, hum, part, (dmg or hum.MaxHealth), Vector3.zero, 2, 0, false) end
end
local shootTillDead = shootPlr

-- ========== LOOP KILL (СКОПИРОВАНА ЛОГИКА ОРИГИНАЛА) ==========
do
    local isAlive = function(p) local c = (p.ClassName == "Player" and p.Character) or p if c then return c:FindFirstChild("Head") end end

    local transTbl = {Zombie = "Humans", Human = "Zombies", Zombies = "NPCs"}
    local teamScan = Teams:GetTeams() table.insert(teamScan, workspace:WaitForChild("Zombies"))

    for _, team in pairs(teamScan) do
        if team and transTbl[team.Name] then
            local tName = transTbl[team.Name] local isTeam = (team.ClassName == "Team")

            Tab.Server:CreateButton({Name = "Kill " .. tName, Callback = function()
                checkTeam(team) findRemote()
                for _, v in pairs((isTeam and plrs:GetPlayers()) or team:GetChildren()) do
                    if (isTeam and lplr ~= v and v.Team ~= lplr.Team and isAlive(v)) or isAlive(v) then shootTillDead(v) end
                end
            end})

            Tab.Server:CreateButton({Name = "God " .. tName, Callback = function()
                checkTeam(team) findRemote()
                for _, v in pairs((isTeam and plrs:GetPlayers()) or team:GetChildren()) do
                    if (isTeam and lplr ~= v and v.Team ~= lplr.Team and isAlive(v)) or isAlive(v) then shootPlr(v, tonumber("nan")) end
                end
                Notify("made " .. tName .. " immune")
            end})

            -- Loop Kill (КАК В ОРИГИНАЛЕ)
            local loopTbl = {}
            local tCons = {}
            local hookChr = function(p)
                if p.ClassName == "Player" and p.Team == lplr.Team then return end
                if isAlive(p) then table.insert(loopTbl, p) end
            end
            local hookPlr = function(p)
                if p.Character then coroutine.wrap(hookChr)(p) end
                table.insert(tCons, p.CharacterAdded:Connect(function(c) hookChr(p) end))
            end

            Tab.Server:CreateToggle({Name = "Loop Kill " .. tName, CurrentValue = false, Callback = function(state)
                if state then
                    checkTeam(team)
                    table.insert(tCons, (isTeam and plrs.PlayerAdded:Connect(hookPlr)) or team.ChildAdded:Connect(hookChr))
                    if isTeam then for _, v in plrs:GetPlayers() do coroutine.wrap(hookPlr)(v) end
                    else for _, v in team:GetChildren() do coroutine.wrap(hookChr)(v) end end

                    task.spawn(function()
                        while state do
                            for i, v in pairs(loopTbl) do
                                if isTeam and v.Team and v.Team == lplr.Team then table.remove(loopTbl, i) continue end
                                if isAlive(v) then findRemote() shootTillDead(v) end
                            end
                            task.wait()
                        end
                        for _, c in pairs(tCons) do c:Disconnect() end
                        table.clear(tCons) table.clear(loopTbl)
                    end)
                else
                    for _, c in pairs(tCons) do c:Disconnect() end
                    table.clear(tCons) table.clear(loopTbl)
                end
            end})
        end
    end
end

