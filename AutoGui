-- Убираем кнопку закрытия, оставляем только свернуть
local function FixOrionButtons()
    local gui = game:GetService("CoreGui"):FindFirstChild("Orion")
    if gui then
        for _, v in ipairs(gui:GetDescendants()) do
            if v:IsA("TextButton") and v.Name == "Close" then
                v:Destroy() -- Удаляем кнопку закрытия
            end
        end
        
        -- Меняем minimize на круг
        for _, v in ipairs(gui:GetDescendants()) do
            if v:IsA("TextButton") and v.Name == "Minimize" then
                v.Size = UDim2.new(0, 40, 0, 40)
                v.Position = UDim2.new(1, -50, 0, 5)
                v.Text = "—"
                v.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
                Instance.new("UICorner", v).CornerRadius = UDim.new(0, 20)
                
                -- Когда свернуто - показываем круг
                local originalCallback = v.MouseButton1Click
                v.MouseButton1Click:Connect(function()
                    task.wait(0.1)
                    spawn(function()
                        for _, circle in ipairs(gui:GetDescendants()) do
                            if circle:IsA("TextButton") and circle.Size == UDim2.new(0, 50, 0, 50) then
                                Instance.new("UICorner", circle).CornerRadius = UDim.new(0, 25)
                                circle.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
                            end
                        end
                    end)
                end)
            end
        end
    end
end

