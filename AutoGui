-- NOTIFICATION
-- =============================================
function AutoGui:Notify(params)
    params = params or {}
    local text = params.Text or "Notification"
    local duration = params.Duration or 3
    local color = params.Color or Color3.fromRGB(80, 180, 255)

    local notif = Instance.new("Frame")
    notif.Name = "Notification"
    notif.Parent = self.ScreenGui
    notif.AnchorPoint = Vector2.new(0.5, 0)
    notif.Position = UDim2.new(0.5, 0, 0, -60)
    notif.Size = UDim2.new(0, 280, 0, 36)
    notif.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    notif.BorderSizePixel = 0
    notif.ZIndex = 100
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", notif):Assign({
        Color = color,
        Thickness = 1.5,
    })

    local notifText = Instance.new("TextLabel")
    notifText.Name = "NotifText"
    notifText.Parent = notif
    notifText.Size = UDim2.new(1, -8, 1, 0)
    notifText.Position = UDim2.new(0, 4, 0, 0)
    notifText.BackgroundTransparency = 1
    notifText.Text = text
    notifText.TextColor3 = Color3.fromRGB(220, 220, 240)
    notifText.TextSize = 12
    notifText.Font = Enum.Font.Gotham
    notifText.ZIndex = 101

    _tween(notif, {Position = UDim2.new(0.5, 0, 0, 10)}, 0.3, Enum.EasingStyle.Back)
    task.delay(duration, function()
        _tween(notif, {Position = UDim2.new(0.5, 0, 0, -60), BackgroundTransparency = 1, TextTransparency = 1}, 0.3)
        task.delay(0.3, function() notif:Destroy() end)
    end)
end

-- =============================================
-- FLAGS / CONFIG
-- =============================================
function AutoGui:SetFlag(key, value)
    self.Flags[key] = value
end

function AutoGui:GetFlag(key)
    return self.Flags[key]
end

function AutoGui:SaveConfig(name)
    name = name or "config"
    local HttpService = game:GetService("HttpService")
    local data = HttpService:JSONEncode(self.Flags)
    if writefile then
        writefile("AutoGui_" .. name .. ".json", data)
    end
    self:Notify({Text = "Config saved: " .. name, Duration = 2, Color = Color3.fromRGB(80, 255, 80)})
end

function AutoGui:LoadConfig(name)
    name = name or "config"
    local HttpService = game:GetService("HttpService")
    if isfile and isfile("AutoGui_" .. name .. ".json") then
        local data = readfile("AutoGui_" .. name .. ".json")
        local decoded = HttpService:JSONDecode(data)
        for k, v in pairs(decoded) do
            self.Flags[k] = v
        end
        self:Notify({Text = "Config loaded: " .. name, Duration = 2, Color = Color3.fromRGB(80, 255, 80)})
    end
end

function AutoGui:Destroy()
    for _, conn in ipairs(self.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    self.ScreenGui:Destroy()
end

return AutoGui
