-- LineSecurity UI Library v2.0
local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local function corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(60, 60, 100)
    s.Thickness = thickness or 1
    s.Parent = parent
    return s
end

local function hover(btn)
    local orig = btn.BackgroundColor3
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(
                math.min(orig.R * 255 + 30, 255),
                math.min(orig.G * 255 + 30, 255),
                math.min(orig.B * 255 + 30, 255)
            )
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), { BackgroundColor3 = orig }):Play()
    end)
end

function Library:CreateWindow(cfg)
    cfg = cfg or {}
    local title = cfg.Title or "Script Hub"
    local w = cfg.Width or 400
    local h = cfg.Height or 320
    local accent = cfg.AccentColor or Color3.fromRGB(0, 170, 255)
    local accent2 = cfg.AccentColor2 or Color3.fromRGB(150, 0, 255)

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "LS_" .. title:gsub("%s", "")
    screenGui.Parent = CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- MAIN FRAME
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Parent = screenGui
    mainFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 20)
    mainFrame.BackgroundTransparency = 1
    mainFrame.BorderSizePixel = 0
    mainFrame.Position = UDim2.new(0.5, -w / 2, 0.5, -h / 2)
    mainFrame.Size = UDim2.new(0, w, 0, h)
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.ClipsDescendants = true
    corner(mainFrame, 12)
    stroke(mainFrame, Color3.fromRGB(40, 40, 70), 1)

    -- HEADER
    local header = Instance.new("Frame")
    header.Name = "Header"
    header.Parent = mainFrame
    header.BackgroundColor3 = Color3.fromRGB(18, 18, 32)
    header.Size = UDim2.new(1, 0, 0, 44)
    header.BorderSizePixel = 0
    corner(header, 12)
    
    -- Header bottom filler
    local headerFill = Instance.new("Frame")
    headerFill.Name = "HeaderFill"
    headerFill.Parent = header
    headerFill.BackgroundColor3 = Color3.fromRGB(18, 18, 32)
    headerFill.Size = UDim2.new(1, 0, 0, 12)
    headerFill.Position = UDim2.new(0, 0, 1, -12)
    headerFill.BorderSizePixel = 0

    -- Title
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Parent = header
    titleLabel.Text = title
    titleLabel.Size = UDim2.new(0, 0, 0, 22)
    titleLabel.Position = UDim2.new(0, 16, 0, 6)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
    titleLabel.TextSize = 16
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.AutomaticSize = Enum.AutomaticSize.X

    -- TAB BAR
    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.Parent = mainFrame
    tabBar.BackgroundColor3 = Color3.fromRGB(14, 14, 26)
    tabBar.Size = UDim2.new(1, 0, 0, 32)
    tabBar.Position = UDim2.new(0, 0, 0, 44)
    tabBar.BorderSizePixel = 0

    -- ACCENT LINE
    local accentLine = Instance.new("Frame")
    accentLine.Name = "AccentLine"
    accentLine.Parent = mainFrame
    accentLine.Size = UDim2.new(1, 0, 0, 3)
    accentLine.Position = UDim2.new(0, 0, 0, 76)
    accentLine.BorderSizePixel = 0
    accentLine.BackgroundColor3 = accent
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new(accent, accent2)
    gradient.Parent = accentLine

    -- CONTENT AREA
    local content = Instance.new("Frame")
    content.Name = "Content"
    content.Parent = mainFrame
    content.BackgroundTransparency = 1
    content.Size = UDim2.new(1, 0, 1, -81)
    content.Position = UDim2.new(0, 0, 0, 81)
    content.BorderSizePixel = 0
    content.ClipsDescendants = true

    -- WINDOW OBJECT
    local window = {}
    window.ScreenGui = screenGui
    window.MainFrame = mainFrame
    window.Content = content
    window.Accent = accent
    window.Tabs = {}
    window.ActiveTab = nil

    -- TAB CREATION
    function window:Tab(name)
        local tabIndex = #self.Tabs + 1
        local btnWidth = math.max(75, #name * 8 + 16)

        -- Tab button
        local tabBtn = Instance.new("TextButton")
        tabBtn.Name = "TabBtn_" .. tabIndex
        tabBtn.Parent = tabBar
        tabBtn.Text = name
        tabBtn.Size = UDim2.new(0, btnWidth, 1, 0)
        tabBtn.Position = UDim2.new(0, (#self.Tabs > 0 and self.Tabs[#self.Tabs].Button.Position.X.Offset + self.Tabs[#self.Tabs].Button.Size.X.Offset + 2) or 4, 0, 0)
        tabBtn.BackgroundColor3 = Color3.fromRGB(14, 14, 26)
        tabBtn.BackgroundTransparency = 1
        tabBtn.TextColor3 = Color3.fromRGB(130, 130, 160)
        tabBtn.TextSize = 11
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.BorderSizePixel = 0
        tabBtn.AutoButtonColor = false
        corner(tabBtn, 5)

        -- Active indicator
        local indicator = Instance.new("Frame")
        indicator.Name = "Indicator"
        indicator.Parent = tabBtn
        indicator.BackgroundColor3 = accent
        indicator.BackgroundTransparency = 1
        indicator.Size = UDim2.new(1, -6, 0, 2)
        indicator.Position = UDim2.new(0, 3, 1, -2)
        indicator.BorderSizePixel = 0

        -- Tab page
        local page = Instance.new("Frame")
        page.Name = "Page_" .. tabIndex
        page.Parent = content
        page.BackgroundTransparency = 1
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BorderSizePixel = 0
        page.Visible = false
        page.ClipsDescendants = true

        -- Scrolling inside page
        local scroll = Instance.new("ScrollingFrame")
        scroll.Name = "Scroll"
        scroll.Parent = page
        scroll.BackgroundTransparency = 1
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.BorderSizePixel = 0
        scroll.ScrollBarThickness = 3
        scroll.ScrollBarImageColor3 = accent
        scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        scroll.ScrollingDirection = Enum.ScrollingDirection.Y
        scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        scroll.ScrollBarImageTransparency = 0.7

        local listLayout = Instance.new("UIListLayout")
        listLayout.Name = "Layout"
        listLayout.Parent = scroll
        listLayout.Padding = UDim.new(0, 5)
        listLayout.SortOrder = Enum.SortOrder.LayoutOrder

        local padding = Instance.new("UIPadding")
        padding.Name = "Padding"
        padding.Parent = scroll
        padding.PaddingTop = UDim.new(0, 6)
        padding.PaddingBottom = UDim.new(0, 6)
        padding.PaddingLeft = UDim.new(0, 4)
        padding.PaddingRight = UDim.new(0, 4)

        -- Tab object
        local tabObj = {
            Button = tabBtn,
            Page = page,
            Scroll = scroll,
            Index = tabIndex,
            Indicator = indicator
        }

        -- SWITCH TAB
        tabBtn.MouseButton1Click:Connect(function()
            for _, t in ipairs(self.Tabs) do
                t.Page.Visible = false
                t.Button.TextColor3 = Color3.fromRGB(130, 130, 160)
                t.Indicator.BackgroundTransparency = 1
            end
            page.Visible = true
            tabBtn.TextColor3 = Color3.fromRGB(230, 230, 240)
            indicator.BackgroundTransparency = 0
            self.ActiveTab = tabObj
        end)

        -- Activate first tab automatically
        if tabIndex == 1 then
            page.Visible = true
            tabBtn.TextColor3 = Color3.fromRGB(230, 230, 240)
            indicator.BackgroundTransparency = 0
            self.ActiveTab = tabObj
        end

        -- TAB ELEMENTS API

        function tabObj:Label(text, color)
            local lbl = Instance.new("TextLabel")
            lbl.Name = "Label"
            lbl.Parent = scroll
            lbl.Text = text
            lbl.Size = UDim2.new(1, 0, 0, 18)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = color or Color3.fromRGB(160, 160, 200)
            lbl.TextSize = 11
            lbl.Font = Enum.Font.Gotham
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.TextWrapped = true
            lbl.AutomaticSize = Enum.AutomaticSize.Y
            return lbl
        end

        function tabObj:Button(text, callback)
            local btn = Instance.new("TextButton")
            btn.Name = "Button"
            btn.Parent = scroll
            btn.Text = text
            btn.Size = UDim2.new(1, 0, 0, 38)
            btn.BackgroundColor3 = Color3.fromRGB(25, 25, 44)
            btn.TextColor3 = Color3.fromRGB(220, 220, 230)
            btn.TextSize = 13
            btn.Font = Enum.Font.GothamBold
            btn.BorderSizePixel = 0
            btn.AutoButtonColor = false
            corner(btn, 8)
            stroke(btn, Color3.fromRGB(50, 50, 75), 1)

            local origBg = btn.BackgroundColor3
            btn.MouseButton1Click:Connect(function()
                TweenService:Create(btn, TweenInfo.new(0.1), {
                    BackgroundColor3 = accent
                }):Play()
                task.delay(0.1, function()
                    TweenService:Create(btn, TweenInfo.new(0.2), {
                        BackgroundColor3 = origBg
                    }):Play()
                end)
                callback()
            end)

            hover(btn)
            return btn
        end

        function tabObj:Toggle(text, default, callback)
            local enabled = default or false
            
            local container = Instance.new("TextButton")
            container.Name = "Toggle"
            container.Parent = scroll
            container.Size = UDim2.new(1, 0, 0, 40)
            container.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
            container.BorderSizePixel = 0
            container.AutoButtonColor = false
            container.Text = ""
            corner(container, 8)
            stroke(container, Color3.fromRGB(45, 45, 70), 1)

            local label = Instance.new("TextLabel")
            label.Name = "Label"
            label.Parent = container
            label.Text = text
            label.Size = UDim2.new(1, -56, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.fromRGB(210, 210, 230)
            label.TextSize = 12
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left

            local switchFrame = Instance.new("Frame")
            switchFrame.Name = "Switch"
            switchFrame.Parent = container
            switchFrame.Size = UDim2.new(0, 40, 0, 20)
            switchFrame.Position = UDim2.new(1, -50, 0.5, -10)
            switchFrame.BorderSizePixel = 0
            corner(switchFrame, 10)

            local switchBg = Instance.new("Frame")
            switchBg.Name = "Bg"
            switchBg.Parent = switchFrame
            switchBg.Size = UDim2.new(1, 0, 1, 0)
            switchBg.BackgroundColor3 = enabled and accent or Color3.fromRGB(55, 55, 75)
            switchBg.BorderSizePixel = 0
            corner(switchBg, 10)

            local dot = Instance.new("Frame")
            dot.Name = "Dot"
            dot.Parent = switchFrame
            dot.Size = UDim2.new(0, 16, 0, 16)
            dot.Position = enabled 
                and UDim2.new(1, -18, 0.5, -8) 
                or UDim2.new(0, 2, 0.5, -8)
            dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            dot.BorderSizePixel = 0
            corner(dot, 8)

            local function updateUI(state)
                enabled = state
                TweenService:Create(switchBg, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
                    BackgroundColor3 = state and accent or Color3.fromRGB(55, 55, 75)
                }):Play()
                TweenService:Create(dot, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
                    Position = state 
                        and UDim2.new(1, -18, 0.5, -8) 
                        or UDim2.new(0, 2, 0.5, -8)
                }):Play()
            end

            container.MouseButton1Click:Connect(function()
                updateUI(not enabled)
                callback(enabled)
            end)

            return {
                Set = function(value)
                    if value ~= enabled then
                        updateUI(value)
                    end
                end,
                Get = function()
                    return enabled
                end
            }
        end

        function tabObj:Textbox(placeholder, callback)
            local container = Instance.new("Frame")
            container.Name = "Textbox"
            container.Parent = scroll
            container.Size = UDim2.new(1, 0, 0, 40)
            container.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
            container.BorderSizePixel = 0
            corner(container, 8)
            stroke(container, Color3.fromRGB(45, 45, 70), 1)

            local icon = Instance.new("TextLabel")
            icon.Name = "Icon"
            icon.Parent = container
            icon.Text = "✎"
            icon.Size = UDim2.new(0, 20, 1, 0)
            icon.Position = UDim2.new(0, 10, 0, 0)
            icon.BackgroundTransparency = 1
            icon.TextColor3 = Color3.fromRGB(130, 130, 160)
            icon.TextSize = 14

            local input = Instance.new("TextBox")
            input.Name = "Input"
            input.Parent = container
            input.PlaceholderText = placeholder or "Введите текст..."
            input.PlaceholderColor3 = Color3.fromRGB(100, 100, 130)
            input.Size = UDim2.new(1, -40, 1, 0)
            input.Position = UDim2.new(0, 34, 0, 0)
            input.BackgroundTransparency = 1
            input.TextColor3 = Color3.fromRGB(220, 220, 240)
            input.TextSize = 12
            input.Font = Enum.Font.Gotham
            input.TextXAlignment = Enum.TextXAlignment.Left
            input.Text = ""
            input.ClearTextOnFocus = false

            input.FocusLost:Connect(function(enterPressed)
                if input.Text ~= "" then
                    callback(input.Text)
                end
            end)

            return {
                Set = function(value)
                    input.Text = value
                end,
                Get = function()
                    return input.Text
                end
            }
        end

        function tabObj:Dropdown(text, options, callback)
            local isOpen = false
            local selected = options[1] or ""
            local optionButtons = {}

            local container = Instance.new("TextButton")
            container.Name = "Dropdown"
            container.Parent = scroll
            container.Size = UDim2.new(1, 0, 0, 40)
            container.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
            container.BorderSizePixel = 0
            container.AutoButtonColor = false
            container.Text = ""
            corner(container, 8)
            stroke(container, Color3.fromRGB(45, 45, 70), 1)

            local label = Instance.new("TextLabel")
            label.Name = "Label"
            label.Parent = container
            label.Text = selected
            label.Size = UDim2.new(1, -30, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.fromRGB(210, 210, 230)
            label.TextSize = 12
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left

            local arrow = Instance.new("TextLabel")
            arrow.Name = "Arrow"
            arrow.Parent = container
            arrow.Text = "▼"
            arrow.Size = UDim2.new(0, 16, 1, 0)
            arrow.Position = UDim2.new(1, -22, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.TextColor3 = Color3.fromRGB(130, 130, 160)
            arrow.TextSize = 12

            local optionList = Instance.new("Frame")
            optionList.Name = "OptionList"
            optionList.Parent = scroll
            optionList.Size = UDim2.new(1, 0, 0, 0)
            optionList.BackgroundColor3 = Color3.fromRGB(16, 16, 28)
            optionList.BorderSizePixel = 0
            optionList.Visible = false
            optionList.ZIndex = 10
            corner(optionList, 6)
            stroke(optionList, Color3.fromRGB(50, 50, 75), 1)

            local optLayout = Instance.new("UIListLayout")
            optLayout.Name = "OptionLayout"
            optLayout.Parent = optionList
            optLayout.Padding = UDim.new(0, 1)
            optLayout.SortOrder = Enum.SortOrder.LayoutOrder

            for _, opt in ipairs(options) do
                local optBtn = Instance.new("TextButton")
                optBtn.Name = "OptBtn"
                optBtn.Parent = optionList
                optBtn.Text = "   " .. opt
                optBtn.Size = UDim2.new(1, 0, 0, 28)
                optBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
                optBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
                optBtn.TextSize = 11
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                optBtn.BorderSizePixel = 0
                optBtn.AutoButtonColor = false
                optBtn.ZIndex = 10
                corner(optBtn, 4)

                optBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    label.Text = opt
                    isOpen = false
                    optionList.Visible = false
                    TweenService:Create(optionList, TweenInfo.new(0.2), {
                        Size = UDim2.new(1, 0, 0, 0)
                    }):Play()
                    callback(selected)
                end)

                hover(optBtn)
                optionButtons[opt] = optBtn
            end

            container.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                optionList.Visible = isOpen
                if isOpen then
                    optionList.Size = UDim2.new(1, 0, 0, 0)
                    TweenService:Create(optionList, TweenInfo.new(0.2), {
                        Size = UDim2.new(1, 0, 0, #options * 29 + 2)
                    }):Play()
                else
                    TweenService:Create(optionList, TweenInfo.new(0.2), {
                        Size = UDim2.new(1, 0, 0, 0)
                    }):Play()
                end
            end)

            return {
                Set = function(value)
                    selected = value
                    label.Text = value
                end,
                Get = function()
                    return selected
                end
            }
        end

        table.insert(self.Tabs, tabObj)
        return tabObj
    end

    -- CLOSE WINDOW
    function window:Close()
        screenGui:Destroy()
    end

    -- MINIMIZE BUTTON
    local minimizeBtn = Instance.new("TextButton")
    minimizeBtn.Name = "Minimize"
    minimizeBtn.Parent = header
    minimizeBtn.Text = "–"
    minimizeBtn.Size = UDim2.new(0, 24, 0, 24)
    minimizeBtn.Position = UDim2.new(1, -30, 0.5, -12)
    minimizeBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    minimizeBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
    minimizeBtn.TextSize = 16
    minimizeBtn.Font = Enum.Font.GothamBold
    minimizeBtn.BorderSizePixel = 0
    minimizeBtn.AutoButtonColor = false
    corner(minimizeBtn, 6)

    -- FLOATING BUBBLE
    local bubble = Instance.new("TextButton")
    bubble.Name = "Bubble"
    bubble.Parent = screenGui
    bubble.Size = UDim2.new(0, 48, 0, 48)
    bubble.Position = UDim2.new(0.88, 0, 0.82, 0)
    bubble.BackgroundColor3 = Color3.fromRGB(12, 12, 20)
    bubble.Text = "⬡"
    bubble.TextSize = 22
    bubble.TextColor3 = Color3.fromRGB(200, 200, 220)
    bubble.BorderSizePixel = 0
    bubble.Visible = false
    bubble.ZIndex = 20
    corner(bubble, 24)
    stroke(bubble, accent, 2)

    minimizeBtn.MouseButton1Click:Connect(function()
        mainFrame.Visible = false
        bubble.Visible = true
    end)

    bubble.MouseButton1Click:Connect(function()
        mainFrame.Visible = true
        bubble.Visible = false
    end)

    -- MAKE BUBBLE DRAGGABLE
    local dragging = false
    local dragStart, startPos

    bubble.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = bubble.Position
        end
    end)

    bubble.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local viewportSize = workspace.CurrentCamera.ViewportSize
            
            local newX = math.clamp(startPos.X.Scale + delta.X / viewportSize.X, 0.02, 0.98)
            local newY = math.clamp(startPos.Y.Scale + delta.Y / viewportSize.Y, 0.02, 0.98)
            
            bubble.Position = UDim2.new(newX, 0, newY, 0)
        end
    end)

    -- SHOW WINDOW WITH ANIMATION
    TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0
    }):Play()

    return window
end

return Library
