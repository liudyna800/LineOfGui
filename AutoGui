    -- Update canvas size
    sectionFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        if tab then
            tab.Page.CanvasSize = UDim2.new(0, 0, 0, tab.Layout.AbsoluteContentSize.Y + 16)
        end
    end)

    return {
        frame = sectionFrame,
        layout = sectionLayout,
        window = self,
    }
end

