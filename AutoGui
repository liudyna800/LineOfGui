function AutoGui:AddTextBox(section, placeholder, callback, params)
    params = params or {}
    local container = Instance.new("Frame")
    container.Name = "TextBox"
    container.Parent = section.frame
    container.Size = UDim2.new(1, 0, 0, _default(params.Height, 34))
    container.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    container.BorderSizePixel = 0
    container.ZIndex = 1
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, _default(params.CornerRadius, 6))
    Instance.new("UIStroke", container):Assign({
        Color = Color3.fromRGB(60, 60, 85),
        Thickness = 1,
    })

    local textBox = Instance.new("TextBox")
    textBox.Name = "TextBoxInput"
    textBox.Parent = container
    textBox.Position = UDim2.new(0, 8, 0, 0)
    textBox.Size = UDim2.new(1, -16, 1, 0)
    textBox.BackgroundTransparency = 1
    textBox.PlaceholderText = placeholder or ""
    textBox.PlaceholderColor3 = Color3.fromRGB(130, 130, 150)
    textBox.Text = _default(params.Default, "")
    textBox.TextColor3 = Color3.fromRGB(220, 220, 240)
