--         GAME INFO
-- ═══════════════════════════════════════════
local function scanGameInfo()
    section("GAME INFO")
    writeln("  PlaceId        = " .. tostring(game.PlaceId))
    writeln("  GameId         = " .. tostring(game.GameId))
    writeln("  PlaceName      = " .. tostring(game.Name))
    writeln("  PlaceVersion   = " .. tostring(game.PlaceVersion))
    writeln("  JobId          = " .. tostring(game.JobId))
    writeln("  PrivateServerId = " .. tostring(game.PrivateServerId))
    writeln("  Creator        = " .. tostring(game.CreatorId) .. " (Type: " .. tostring(game.CreatorType) .. ")")
    writeln("")
    if LocalPlayer then
        writeln("  LocalPlayer:")
        writeln("    Name           = " .. tostring(LocalPlayer.Name))
        writeln("    DisplayName    = " .. tostring(LocalPlayer.DisplayName))
        writeln("    UserId         = " .. tostring(LocalPlayer.UserId))
        writeln("    AccountAge     = " .. tostring(LocalPlayer.AccountAge))
        writeln("    MembershipType = " .. tostring(LocalPlayer.MembershipType))
        writeln("")
    end
    local rs = Services.RunService
    writeln("  RunService:")
    writeln("    IsClient = " .. tostring(rs:IsClient()))
    writeln("    IsServer = " .. tostring(rs:IsServer()))
    writeln("    IsStudio = " .. tostring(rs:IsStudio()))
    writeln("")
end

