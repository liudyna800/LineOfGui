local function scanPlayers()
    if not CONFIG.SCAN_PLAYERS then return end
    section("PLAYERS — Данные игроков")

    local players = Services.Players:GetPlayers()
    writeln("  Игроков в игре: " .. #players)
    writeln("")

    for _, player in ipairs(players) do
        scanStats.players = scanStats.players + 1
        local okName, dispName = pcall(function() return player.DisplayName end)
        writeln("  [PLAYER] " .. player.Name .. " (@" .. (okName and dispName or "?") .. ")")
        writeln("     UserId       = " .. tostring(player.UserId))
        writeln("     AccountAge   = " .. tostring(player.AccountAge) .. " дней")
        writeln("     TeamColor    = " .. tostring(player.TeamColor))

        -- Leaderstats
        local ls = player:FindFirstChild("leaderstats")
        if ls then
            writeln("     [leaderstats]:")
            for _, stat in ipairs(ls:GetChildren()) do
                local val = safeGet(stat, "Value")
                writeln("        " .. stat.Name .. " [" .. stat.ClassName .. "] = " .. (val or "?"))
            end
        end

        -- PlayerGui — только для LocalPlayer (нет доступа к чужим)
        if player == LocalPlayer then
            local pg = player:FindFirstChildOfClass("PlayerGui")
            if pg then
                writeln("     [PlayerGui] (" .. safeChildCount(pg) .. " GUIs):")
                for _, gui in ipairs(pg:GetChildren()) do
                    writeln("        [" .. gui.ClassName .. "] " .. gui.Name)
                    local enabled = safeGet(gui, "Enabled")
                    if enabled then writeln("           Enabled = " .. enabled) end
                end
            end
        end

        -- Backpack
        local bp = player:FindFirstChildOfClass("Backpack")
        if bp then
            local tools = bp:GetChildren()
            if #tools > 0 then
                writeln("     [Backpack] (" .. #tools .. " инструментов):")
                for _, tool in ipairs(tools) do
                    writeln("        [" .. tool.ClassName .. "] " .. tool.Name)
                    local tt = safeGet(tool, "ToolTip")
                    if tt and tt ~= "" then writeln("           ToolTip = " .. tt) end
                end
            end
        end

        -- Character
        local char = player.Character
        if char then
            writeln("     [Character] " .. char.Name)
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos = safeGet(hrp, "Position")
                if pos then writeln("        Position = " .. pos) end
            end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                writeln("        Health     = " .. (safeGet(hum, "Health") or "?"))
                writeln("        MaxHealth  = " .. (safeGet(hum, "MaxHealth") or "?"))
                writeln("        WalkSpeed  = " .. (safeGet(hum, "WalkSpeed") or "?"))
                writeln("        JumpPower  = " .. (safeGet(hum, "JumpPower") or "?"))

                -- БАГ #7 ИСПРАВЛЕН: FindFirstChildOfClass("Humanoid") вызывался
                -- дважды подряд на char — дублирование и риск nil-цепочки.
                -- Теперь используется уже найденный hum.
                local animator = hum:FindFirstChildOfClass("Animator")
                if animator then
                    local okT, tracks = pcall(function() return animator:GetPlayingAnimationTracks() end)
                    if okT and tracks and #tracks > 0 then
                        writeln("        [Playing Animations]:")
                        for _, track in ipairs(tracks) do
                            local spd = safeGet(track, "Speed") or "?"
                            writeln("           " .. track.Name .. " (Speed: " .. spd .. ")")
                        end
                    end
                end
            end
        end

        getAttributes(player, 2)
        writeln("")
    end
end

-- ═══════════════════════════════════════════
--       СКАНЕР REMOTE EVENTS
-- ═══════════════════════════════════════════
local function findAllRemotes(parent, results)
    local ok, children = pcall(function() return parent:GetChildren() end)
    if not ok then return end
    for _, child in ipairs(children) do
        if REMOTE_CLASSES[child.ClassName] then
            local okP, fp = pcall(function() return child:GetFullName() end)
            table.insert(results, {
                path  = okP and fp or child.Name,
                class = child.ClassName,
                name  = child.Name,
            })
        end
        findAllRemotes(child, results)
    end
end

local function scanRemotes()
    if not CONFIG.SCAN_REMOTES then return end
    section("REMOTES — RemoteEvents / RemoteFunctions / Bindables")

    local allRemotes = {}
    findAllRemotes(game, allRemotes)
    writeln("  Найдено: " .. #allRemotes)
    writeln("")

    local groups = {
        RemoteEvent={}, RemoteFunction={},
        BindableEvent={}, BindableFunction={},
        UnreliableRemoteEvent={},
    }
    for _, r in ipairs(allRemotes) do
        if groups[r.class] then
            table.insert(groups[r.class], r)
        end
    end

    local labels = {
        RemoteEvent="[RemoteEvent]", RemoteFunction="[RemoteFunction]",
        BindableEvent="[BindableEvent]", BindableFunction="[BindableFunction]",
        UnreliableRemoteEvent="[UnreliableRemoteEvent]",
    }

    -- БАГ #8 ИСПРАВЛЕН: r.path:sub(5) обрезал первые 4 байта строки "game",
    -- но GetFullName() возвращает "game.ReplicatedStorage.X" — нужно убирать
    -- слово "game", а не 4 байта. Теперь используется gsub для надёжности.
    for class, list in pairs(groups) do
        if #list > 0 then
            writeln("  " .. (labels[class] or class) .. " (" .. #list .. "):")
            for _, r in ipairs(list) do
                writeln("     * " .. r.name)
                writeln("       Path: " .. r.path)
                -- Строим корректный accessor: убираем ведущий "game"
                local accessor = r.path:gsub("^game", "game")
                if class == "RemoteEvent" then
                    writeln("       -- FireServer:    " .. accessor .. ":FireServer(...)")
                    writeln("       -- OnClientEvent: " .. accessor .. ".OnClientEvent:Connect(function(...) end)")
                elseif class == "RemoteFunction" then
                    writeln("       -- InvokeServer:  " .. accessor .. ":InvokeServer(...)")
                end
            end
            writeln("")
        end
    end

    -- Готовый код-шаблон для всех RemoteEvents
    if #groups["RemoteEvent"] > 0 then
        writeln("  -- Шаблон подключения всех RemoteEvents:")
        writeln("")
        for _, r in ipairs(groups["RemoteEvent"]) do
            -- Безопасное имя переменной
            local varName = r.name:gsub("[^%w]", "_")
            -- Путь до родителя (всё кроме последнего сегмента)
            local parentPath = r.path:match("^(.+)%.[^%.]+$") or "game.ReplicatedStorage"
            writeln('  local ' .. varName .. ' = ' .. parentPath .. ':WaitForChild("' .. r.name .. '")')
            writeln('  ' .. varName .. '.OnClientEvent:Connect(function(...)')
            writeln('      print("[' .. r.name .. '] args:", ...)')
            writeln('  end)')
            writeln("")
        end
    end
end

-- ═══════════════════════════════════════════
--        СКАНЕР СКРИПТОВ
-- ═══════════════════════════════════════════
local function findAllScripts(parent, results)
    local ok, children = pcall(function() return parent:GetChildren() end)
    if not ok then return end
    for _, child in ipairs(children) do
        if SCRIPT_CLASSES[child.ClassName] then
            table.insert(results, child)
        end
        findAllScripts(child, results)
    end
end

local function scanScripts()
    if not CONFIG.SCAN_SCRIPTS then return end
    section("SCRIPTS — Все скрипты в игре")

    local allScripts = {}
    findAllScripts(game, allScripts)
    writeln("  Найдено: " .. #allScripts)
    writeln("")

    local byClass = {Script={}, LocalScript={}, ModuleScript={}}
    for _, s in ipairs(allScripts) do
        if byClass[s.ClassName] then
            table.insert(byClass[s.ClassName], s)
        end
    end

    -- Фиксированный порядок вывода
    for _, class in ipairs({"LocalScript", "Script", "ModuleScript"}) do
        local list = byClass[class]
        if #list > 0 then
            writeln("  [" .. class .. "] (" .. #list .. "):")
            for _, s in ipairs(list) do
                local disabled = safeGet(s, "Disabled")
                local okFP, fp = pcall(function() return s:GetFullName() end)
                -- БАГ исправлен: disabled — boolean, tostring даёт "true"/"false",
                -- сравнение со строкой "true" работало, но неявно.
                -- Теперь сравниваем с реальным булевым значением.
                local disabledBool = (disabled == "true" or disabled == true)
                local line = "     * " .. s.Name .. "  ->  " .. (okFP and fp or s.Name)
                if disabledBool then line = line .. "  [DISABLED]" end
                writeln(line)
            end
            writeln("")
        end
    end
end

