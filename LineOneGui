local function getAttributes(obj, depth)
    if not CONFIG.INCLUDE_ATTRIBUTES then return end
    local ok, attrs = pcall(function() return obj:GetAttributes() end)
    if not ok or not attrs then return end
    local count = 0
    for _ in pairs(attrs) do count = count + 1 end
    if count > 0 then
        writeln(indent(depth) .. "  [ATTR]:")
        for k, v in pairs(attrs) do
            writeln(indent(depth) .. "     " .. tostring(k) .. " = " .. tostring(v) .. " (" .. typeof(v) .. ")")
        end
    end
end

