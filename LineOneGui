        end
        
        local tabMethods = {}
        
        function tabMethods:CreateButton(btnText, callback, ...)
            local args = {...}
            local button = Instance.new("TextButton")
            button.Size = UDim2.new(1, 0, 0, 34)
            button.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
