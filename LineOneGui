-- ============ СОБСТВЕННАЯ GUI БИБЛИОТЕКА ============
local GuiLibrary = {}

function GuiLibrary:CreateWindow(config)
    config = config or {}
    local title = config.Title or "Delta Hub"
    
    -- ScreenGui
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = title
    ScreenGui.Parent = game:GetService("CoreGui")
    syn.protect_gui and syn.protect_gui(ScreenGui)
    
    -- Затемнение фона
    local Background = Instance.new("Frame")
    Background.Size = UDim2.new(1, 0, 1, 0)
    Background.BackgroundTransparency = 1
    Background.Parent = ScreenGui
    
    -- Главное окно
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 550, 0, 350)
    MainFrame.Position = UDim2.new(0.5, -275, 0.5, -175)
    MainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = Background
    
    -- Скругление углов
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
    
    -- Тень
    local Shadow = Instance.new("ImageLabel")
    Shadow.Size = UDim2.new(1, 20, 1, 20)
    Shadow.Position = UDim2.new(0, -10, 0, -10)
    Shadow.BackgroundTransparency = 1
    Shadow.Image = "rbxassetid://5028857084"
    Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    Shadow.ImageTransparency = 0.7
    Shadow.ScaleType = Enum.ScaleType.Slice
    Shadow.SliceCenter = Rect.new(10, 10, 118, 118)
    Shadow.Parent = MainFrame
    Shadow.ZIndex = 0
    
    -- Заголовок
    local TitleBar = Instance.new("Frame")
    TitleBar.Size = UDim2.new(1, 0, 0, 35)
    TitleBar.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    TitleBar.BorderSizePixel = 0
    TitleBar.Parent = MainFrame
    TitleBar.ZIndex = 2
    
    Instance.new("UICorner", TitleBar).CornerRadius = UDim.new(0, 8)
    
    local TitleText = Instance.new("TextLabel")
    TitleText.Size = UDim2.new(1, -80, 1, 0)
    TitleText.Position = UDim2.new(0, 15, 0, 0)
    TitleText.BackgroundTransparency = 1
    TitleText.Text = title
    TitleText.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleText.Font = Enum.Font.GothamBold
    TitleText.TextSize = 14
    TitleText.TextXAlignment = Enum.TextXAlignment.Left
    TitleText.Parent = TitleBar
    TitleText.ZIndex = 2
    
    -- Кнопка "Свернуть в круг"
    local MinimizeButton = Instance.new("TextButton")
    MinimizeButton.Size = UDim2.new(0, 30, 0, 30)
    MinimizeButton.Position = UDim2.new(1, -40, 0, 5)
    MinimizeButton.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    MinimizeButton.Text = "—"
    MinimizeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    MinimizeButton.Font = Enum.Font.GothamBold
    MinimizeButton.TextSize = 18
    MinimizeButton.Parent = TitleBar
    MinimizeButton.ZIndex = 3
    
    Instance.new("UICorner", MinimizeButton).CornerRadius = UDim.new(0, 15)
    
    local Minimized = false
    local MinimizedCircle
    
    MinimizeButton.MouseButton1Click:Connect(function()
        Minimized = not Minimized
        if Minimized then
            MainFrame.Visible = false
            MinimizedCircle = Instance.new("TextButton")
            MinimizedCircle.Size = UDim2.new(0, 50, 0, 50)
            MinimizedCircle.Position = UDim2.new(1, -70, 0, 20)
            MinimizedCircle.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
            MinimizedCircle.Text = "D"
            MinimizedCircle.TextColor3 = Color3.fromRGB(255, 255, 255)
            MinimizedCircle.Font = Enum.Font.GothamBold
            MinimizedCircle.TextSize = 24
            MinimizedCircle.Parent = Background
            Instance.new("UICorner", MinimizedCircle).CornerRadius = UDim.new(0, 25)
            
            MinimizedCircle.MouseButton1Click:Connect(function()
                Minimized = false
                MainFrame.Visible = true
                MinimizedCircle:Destroy()
            end)
            
            -- Перетаскивание круга
            local dragging
            local dragStart
            local startPos
            MinimizedCircle.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    dragStart = input.Position
                    startPos = MinimizedCircle.Position
                end
            end)
            MinimizedCircle.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            game:GetService("UserInputService").InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local delta = input.Position - dragStart
                    MinimizedCircle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end)
        else
            MainFrame.Visible = true
            if MinimizedCircle then
                MinimizedCircle:Destroy()
            end
        end
    end)
    
    -- Панель вкладок (слева)
    local TabPanel = Instance.new("Frame")
    TabPanel.Size = UDim2.new(0, 140, 1, -35)
    TabPanel.Position = UDim2.new(0, 0, 0, 35)
    TabPanel.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    TabPanel.BorderSizePixel = 0
    TabPanel.Parent = MainFrame
    TabPanel.ZIndex = 1
    
    local TabButtons = {}
    local ContentFrames = {}
    
    -- Разделитель
    local Divider = Instance.new("Frame")
    Divider.Size = UDim2.new(0, 2, 1, 0)
    Divider.Position = UDim2.new(1, 0, 0, 0)
    Divider.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Divider.BorderSizePixel = 0
    Divider.Parent = TabPanel
    
    -- Контейнер контента (справа)
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -142, 1, -35)
    ContentContainer.Position = UDim2.new(0, 142, 0, 35)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame
    ContentContainer.ZIndex = 1
    
    -- Функция создания вкладки
    function GuiLibrary:CreateTab(tabName)
        local tabButton = Instance.new("TextButton")
        tabButton.Size = UDim2.new(1, 0, 0, 32)
        tabButton.BackgroundTransparency = 1
        tabButton.Text = tabName
        tabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        tabButton.Font = Enum.Font.Gotham
        tabButton.TextSize = 13
        tabButton.Parent = TabPanel
        
        local contentFrame = Instance.new("ScrollingFrame")
        contentFrame.Size = UDim2.new(1, 0, 1, 0)
        contentFrame.BackgroundTransparency = 1
        contentFrame.Visible = false
        contentFrame.ScrollBarThickness = 4
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        contentFrame.Parent = ContentContainer
        
        local UIListLayout = Instance.new("UIListLayout")
        UIListLayout.Padding = UDim.new(0, 8)
        UIListLayout.Parent = contentFrame
        
        table.insert(TabButtons, {button = tabButton, frame = contentFrame})
        
        tabButton.MouseButton1Click:Connect(function()
            for _, tab in pairs(TabButtons) do
                tab.frame.Visible = false
                tab.button.TextColor3 = Color3.fromRGB(180, 180, 180)
            end
            contentFrame.Visible = true
            tabButton.TextColor3 = Color3.fromRGB(100, 180, 255)
        end)
        
        if #TabButtons == 1 then
            contentFrame.Visible = true
            tabButton.TextColor3 = Color3.fromRGB(100, 180, 255)
        end
        
        return contentFrame
    end
    
    -- Перетаскивание окна
    local dragging
    local dragStart
    local startPos
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    return GuiLibrary
end

function GuiLibrary:CreateButton(contentFrame, buttonText, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -16, 0, 36)
    button.Position = UDim2.new(0, 8, 0, 0)
    button.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    button.Text = "  " .. buttonText
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.Gotham
    button.TextSize = 13
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Parent = contentFrame
    
    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 4)
    
    button.MouseButton1Click:Connect(function()
        callback()
    end)
    
    contentFrame.CanvasSize = UDim2.new(0, 0, 0, contentFrame.UIListLayout.AbsoluteContentSize.Y + 16)
    contentFrame.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, contentFrame.UIListLayout.AbsoluteContentSize.Y + 16)
    end)
    
    return button
end

function GuiLibrary:CreateToggle(contentFrame, toggleText, callback)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -16, 0, 36)
    toggleFrame.Position = UDim2.new(0, 8, 0, 0)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    toggleFrame.Parent = contentFrame
    
    Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(0, 4)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = toggleText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame
    
    local toggle = Instance.new("Frame")
    toggle.Size = UDim2.new(0, 40, 0, 20)
    toggle.Position = UDim2.new(1, -50, 0.5, -10)
    toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
    toggle.Parent = toggleFrame
    
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 10)
    
    local toggleDot = Instance.new("Frame")
    toggleDot.Size = UDim2.new(0, 16, 0, 16)
    toggleDot.Position = UDim2.new(0, 2, 0.5, -8)
    toggleDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toggleDot.Parent = toggle
    
    Instance.new("UICorner", toggleDot).CornerRadius = UDim.new(0, 8)
    
    local enabled = false
    
    toggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            enabled = not enabled
            if enabled then
                toggle.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
                toggleDot:TweenPosition(UDim2.new(1, -18, 0.5, -8), "Out", "Quad", 0.15, true)
            else
                toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
                toggleDot:TweenPosition(UDim2.new(0, 2, 0.5, -8), "Out", "Quad", 0.15, true)
            end
            callback(enabled)
        end
    end)
    
    contentFrame.CanvasSize = UDim2.new(0, 0, 0, contentFrame.UIListLayout.AbsoluteContentSize.Y + 16)
    contentFrame.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, contentFrame.UIListLayout.AbsoluteContentSize.Y + 16)
    end)
    
    return {Enabled = enabled, toggleFrame = toggleFrame}
end

