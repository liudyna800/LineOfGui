-- Загрузка библиотеки Rayfield
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Создание главного окна
local Window = Rayfield:CreateWindow({
   Name = "Facility of Redemption | Эксплоит Хаб",
   LoadingTitle = "Загрузка уязвимостей Delta...",
   LoadingSubtitle = "by AI Collaborator",
   Theme = "Default", -- Можно сменить на DarkTheme, Ocean и т.д.
   DisableRayfieldPrompts = false
})

-- Переменные для работы функций
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local killAuraEnabled = false
local autoLootEnabled = false

-- =============================================================================
-- ВКЛАДКА: КИЛЛ-АУРА И БОЙ
-- =============================================================================
local CombatTab = Window:CreateTab("⚔️ Бой / Килл-Аура", nil)

CombatTab:CreateSection("Описание уязвимости")
CombatTab:CreateParagraph({
    Title = "Что это такое?", 
    Content = "Использует дыру в защите события 'OnWeaponDealtDamage'. Сервер не проверяет, держишь ли ты оружие в руках и находишься ли рядом с целью. Позволяет бить врагов на дистанции."
})

CombatTab:CreateSection("Настройки функции")
CombatTab:CreateToggle({
   Name = "Активировать Килл-Ауру",
   CurrentValue = false,
   Flag = "KillAuraFlag",
   Callback = function(Value)
      killAuraEnabled = Value
      if killAuraEnabled then
          task.spawn(function()
              while killAuraEnabled do
                  local damageRemote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("OnWeaponDealtDamage")
                  if damageRemote then
                      for _, p in ipairs(Players:GetPlayers()) do
                          if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                              -- Триггерим нанесение урона напрямую на сервер
                              damageRemote:FireServer(p.Character.Humanoid, 50) 
                          end
                      end
                  end
                  task.wait(0.3) -- Безопасная задержка, чтобы не крашнуло по лимиту пакетов
              end
          end)
      end
   end,
})

-- =============================================================================
-- ВКЛАДКА: ДЛЯ ЛЮДЕЙ (HUMANS)
-- =============================================================================
local HumanTab = Window:CreateTab("🧑 Фракция: Люди", nil)

HumanTab:CreateSection("Когда использовать?")
HumanTab:CreateParagraph({
    Title = "Инструкция", 
    Content = "Используй эти функции, если ты играешь за выживших (Людей). Помогает быстро собрать лучшее оружие на карте, хилки и сбежать от монстров через закрытые двери."
})

HumanTab:CreateSection("Управление")
HumanTab:CreateToggle({
   Name = "Авто-сбор предметов (Мачете, Катана, Стимуляторы)",
   CurrentValue = false,
   Flag = "AutoLootFlag",
   Callback = function(Value)
       autoLootEnabled = Value
       if autoLootEnabled then
           task.spawn(function()
               while autoLootEnabled do
                   local pickItems = Workspace:FindFirstChild("PickItem")
                   local char = LocalPlayer.Character
                   local hrp = char and char:FindFirstChild("HumanoidRootPart")
                   
                   if pickItems and hrp then
                       for _, item in ipairs(pickItems:GetChildren()) do
                           local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                           local part = item:FindFirstChildWhichIsA("BasePart", true)
                           
                           if prompt and part then
                               -- Мгновенно прожимаем сбор со всей карты
                               fireproximityprompt(prompt)
                           end
                       end
                   end
                   task.wait(2) -- Проверка карты на новые предметы каждые 2 секунды
               end
           end)
       end
   end,
})

HumanTab:CreateButton({
   Name = "Взломать и открыть все двери/шкафы на карте",
   Callback = function()
       local count = 0
       if Workspace:FindFirstChild("Map") then
           for _, obj in ipairs(Workspace.Map:GetDescendants()) do
               if obj:IsA("ProximityPrompt") then
                   obj.HoldDuration = 0 -- Убираем задержку удержания кнопки
                   fireproximityprompt(obj)
                   count = count + 1
               end
           end
           Rayfield:Notify({Title = "Успешно!", Content = "Взломано объектов на карте: " .. tostring(count), Duration = 3})
       else
           Rayfield:Notify({Title = "Ошибка", Content = "Папка папки Map не найдена в Workspace", Duration = 3})
       end
   end,
})

-- =============================================================================
-- ВКЛАДКА: ДЛЯ МОНСТРОВ (GOOBEAST)
-- =============================================================================
local BeastTab = Window:CreateTab("🦠 Фракция: GooBeast", nil)

BeastTab:CreateSection("Когда использовать?")
BeastTab:CreateParagraph({
    Title = "Инструкция", 
    Content = "Используй во время игры за зараженных. Позволяет моментально выслеживать выживших сквозь любые препятствия стен лаборатории и ломать их защиту."
})

BeastTab:CreateSection("Управление")
BeastTab:CreateButton({
   Name = "Активировать Wallhack / ESP на всех людей",
   Callback = function()
       for _, p in ipairs(Players:GetPlayers()) do
           if p ~= LocalPlayer and p.Character then
               -- Удаляем старый ESP если был
               if p.Character:FindFirstChild("BeastESP") then p.Character.BeastESP:Destroy() end
               
               -- Создаем красивую подсветку Rayfield-стиля
               local highlight = Instance.new("Highlight")
               highlight.Name = "BeastESP"
               highlight.FillColor = Color3.fromRGB(0, 255, 128)
               highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
               highlight.FillTransparency = 0.4
               highlight.Parent = p.Character
           end
       end
       Rayfield:Notify({Title = "ESP включен", Content = "Все игроки теперь подсвечиваются сквозь стены", Duration = 3})
   end,
})

-- =============================================================================
-- ВКЛАДКА: СМЕНА КОМАНДЫ (TEAM EXPLOITS)
-- =============================================================================
local TeamTab = Window:CreateTab("🔄 Смена Фракции", nil)

TeamTab:CreateSection("Что это такое?")
TeamTab:CreateParagraph({
    Title = "Обход выбора фракции", 
    Content = "Сервер принимает запросы на смену команды в любой момент времени через незащищенную папку Team в ReplicatedStorage."
})

TeamTab:CreateSection("Выбор стороны")
TeamTab:CreateButton({
   Name = "Стать Человеком (Human)",
   Callback = function()
       local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("Team") and ReplicatedStorage.RemoteEvents.Team:FindFirstChild("Human")
       if remote then 
           remote:FireServer() 
       else
           Rayfield:Notify({Title = "Ошибка", Content = "Ремоут смены команды не найден", Duration = 3})
       end
   end,
})

TeamTab:CreateButton({
   Name = "Стать Монстром (GooBeast)",
   Callback = function()
       local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("Team") and ReplicatedStorage.RemoteEvents.Team:FindFirstChild("GooBeast")
       if remote then 
           remote:FireServer() 
       else
           Rayfield:Notify({Title = "Ошибка", Content = "Ремоут смены команды не найден", Duration = 3})
       end
   end,
})

-- Уведомление об успешной инициализации всего интерфейса
Rayfield:Notify({
   Name = "Скрипт Готов!",
   Content = "Все уязвимости Facility of Redemption успешно подгружены в Rayfield.",
   Duration = 5,
   Image = 4483362458,
})
