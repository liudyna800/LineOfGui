-- Delta Explorer v2.2 — Daycare Scanner
-- Сканирует всю игру и пишет в файл

local out = ""
local function w(s) out = out .. (s or "") .. "\n" end
local function sep(t) w("\n=== " .. t .. " ===\n") end

local function safeGetService(n)
    local ok, s = pcall(function() return game:GetService(n) end)
    return ok and s or nil
end

local function val2str(v)
    if v == nil then return "nil" end
    local t = typeof(v)
    if t == "Instance" then
        local ok, p = pcall(function() return v:GetFullName() end)
        return "[" .. v.ClassName .. "] " .. (ok and p or "?")
    elseif t == "CFrame" then return ("CFrame(%.2f,%.2f,%.2f)"):format(v.X,v.Y,v.Z)
    elseif t == "Vector3" then return ("V3(%.2f,%.2f,%.2f)"):format(v.X,v.Y,v.Z)
    elseif t == "Color3" then return ("Color3(%.2f,%.2f,%.2f)"):format(v.R,v.G,v.B)
    elseif t == "UDim2" then return ("UDim2(%.2f,%d,%.2f,%d)"):format(v.X.Scale,v.X.Offset,v.Y.Scale,v.Y.Offset)
    else return tostring(v) end
end

local function safeGet(o, p)
    local ok, v = pcall(function() return o[p] end)
    return ok and v ~= nil and val2str(v) or nil
end

-- Рекурсивный обход
local function scan(obj, depth, maxd)
    if maxd and maxd > 0 and depth > maxd then return end
    local ok, children = pcall(function() return obj:GetChildren() end)
    if not ok then return end
    for _, c in ipairs(children) do
        local okFP, fp = pcall(function() return c:GetFullName() end)
        local path = okFP and fp or c.Name
        local okCC, cc = pcall(function() return #c:GetChildren() end)
        local childCount = okCC and cc or 0

        w(string.rep("  ", depth) .. "[" .. c.ClassName .. "] " .. c.Name .. " | " .. path .. " | children:" .. childCount)

        -- Атрибуты
        local okA, attrs = pcall(function() return c:GetAttributes() end)
        if okA and attrs then
            for k, v in pairs(attrs) do
                w(string.rep("  ", depth) .. "  ATTR: " .. tostring(k) .. " = " .. tostring(v))
            end
        end

        -- Свойства по классу
        local cls = c.ClassName
        local props = {
            Part={"Position","Size","Anchored","CanCollide","Material","BrickColor","Transparency"},
            MeshPart={"Position","Size","Anchored","MeshId","TextureID"},
            UnionOperation={"Position","Size","Anchored"},
            Model={"PrimaryPart","WorldPivot"},
            Tool={"ToolTip","RequiresHandle","GripPos","GripForward","GripUp"},
            Animation={"AnimationId"},
            Humanoid={"MaxHealth","Health","WalkSpeed","JumpPower","DisplayName","RigType"},
            NumberValue={"Value"},StringValue={"Value"},BoolValue={"Value"},
            IntValue={"Value"},ObjectValue={"Value"},
            NumberConstrainedValue={"Value","MinValue","MaxValue"},
            Sound={"SoundId","Volume","Looped","Playing","TimePosition"},
            RemoteEvent={},RemoteFunction={},BindableEvent={},BindableFunction={},
            UnreliableRemoteEvent={},
            Script={"Disabled","RunContext"},LocalScript={"Disabled"},ModuleScript={},
            ScreenGui={"Enabled","ResetOnSpawn","DisplayOrder","ZIndexBehavior"},
            Frame={"Size","Position","Visible","BackgroundColor3","BackgroundTransparency"},
            TextLabel={"Text","TextSize","TextColor3","Visible","Font"},
            TextButton={"Text","TextSize","TextColor3","Visible","Font"},
            TextBox={"Text","PlaceholderText","Visible"},
            ImageLabel={"Image","ImageColor3","Visible"},
            ImageButton={"Image","ImageColor3","Visible"},
            ScrollingFrame={"CanvasSize","ScrollingDirection","Visible"},
            ProximityPrompt={"ActionText","ObjectText","KeyboardKeyCode","HoldDuration","MaxActivationDistance"},
            Seat={"Disabled"},
            VehicleSeat={"MaxSpeed","Throttle","Steer","Disabled"},
            SpawnLocation={"TeamColor","AllowTeamChangeOnTouch","Enabled"},
            Team={"TeamColor","AutoAssignable"},
            Fire={"Color","SecondaryColor","Heat","Size"},
            Smoke={"Color","Density","RiseVelocity","Opacity"},
            Sparkles={"SparkleColor"},
            Decal={"Texture","Face","Transparency"},
            SpecialMesh={"MeshId","TextureId","MeshType","Scale"},
            Motor6D={"C0","C1","Part0","Part1"},
            Weld={"C0","C1","Part0","Part1"},
            BillboardGui={"Size","StudsOffset","Enabled","AlwaysOnTop"},
            SurfaceGui={"Enabled","Face"},
            SelectionBox={"Color3","LineThickness"},
            BodyVelocity={"Velocity","MaxForce"},
            BodyPosition={"Position","MaxForce"},
            BodyGyro={"CFrame","MaxTorque"},
            Folder={},Configuration={},
            Animator={},
        }
        local pp = props[cls]
        if pp then
            for _, pr in ipairs(pp) do
                local v = safeGet(c, pr)
                if v then w(string.rep("  ",depth).."  "..pr.." = "..v) end
            end
        end

        if childCount > 0 then
            scan(c, depth + 1, maxd)
        end
    end
end

