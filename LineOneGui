-- Загрузка библиотеки Rayfield
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Создание главного окна
local Window = Rayfield:CreateWindow({
   Name = "Facility of Redemption | Легит Автоматизация",
   LoadingTitle = "Подготовка интерфейса...",
   LoadingSubtitle = "Безопасные механики",
   Theme = "Default",
   DisableRayfieldPrompts = false
})

-- Сервисы и переменные
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local hitboxesEnabled = false
local autoClickerEnabled = false
local customHitboxSize = 4

-- =============================================================================
-- ВКЛАДКА: БОЕВЫЕ МЕХАНИКИ (COMBAT)
-- =============================================================================
local CombatTab = Window:CreateTab("⚔️ Боевые Функции", nil)

CombatTab:CreateSection("Описание механизмов")
CombatTab:CreateParagraph({
    Title = "Как это работает?", 
    Content = "Вместо отправки опасных сетевых пакетов, которые вызывают кик, данный раздел использует легитимное расширение зон попадания (Хитбоксов) и симуляцию нажатий. Это позволяет попадать по врагам без риска блокировки со стороны сервера."
})

CombatTab:CreateSection("Модификация окружения")
CombatTab:CreateSlider({
   Name = "Размер хитбокса противников",
   Min = 2,
   Max = 15,
   Default = 4,
   Color = Color3.fromRGB(255, 128, 0),
   Increment = 1,
   ValueName = "studs",
   Callback = function(Value)
      customHitboxSize = Value
   end,
})

CombatTab:CreateToggle({
   Name = "Расширить хитбоксы (Легит Аура)",
   CurrentValue = false,
   Flag = "HitboxToggle",
   Callback = function(Value)
      hitboxesEnabled = Value
      if hitboxesEnabled then
          task.spawn(function()
              while hitboxesEnabled do
                  for _, p in ipairs(Players:GetPlayers()) do
                      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                          local hrp = p.Character.HumanoidRootPart
                          hrp.Size = Vector3.new(customHitboxSize, customHitboxSize, customHitboxSize)
                          hrp.Transparency = 0.7
                          hrp.Color = Color3.fromRGB(255, 0, 0)
                          hrp.Material = Enum.Material.Neon
                          hrp.CanCollide = false
                      end
                  end
                  task.wait(1)
              end
          end)
      else
          -- Сброс хитбоксов к стандартным значениям
          for _, p in ipairs(Players:GetPlayers()) do
              if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                  local hrp = p.Character.HumanoidRootPart
                  hrp.Size = Vector3.new(2, 2, 1)
                  hrp.Transparency = 0
                  hrp.CanCollide = true
              end
          end
      end
   end,
})

CombatTab:CreateToggle({
   Name = "Автоматический кликер (Для оружия)",
   CurrentValue = false,
   Flag = "AutoClickerToggle",
   Callback = function(Value)
      autoClickerEnabled = Value
      if autoClickerEnabled then
          task.spawn(function()
              while autoClickerEnabled do
                  local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                  if tool then
                      tool:Activate()
                  end
                  task.wait(0.1) -- Безопасный интервал нажатия
              end
          end)
      end
   end,
})

-- =============================================================================
-- ВКЛАДКА: ДВИЖЕНИЕ И ФИЗИКА (MOVEMENT)
-- =============================================================================
local MoveTab = Window:CreateTab("⚡ Подвижность", nil)

MoveTab:CreateSection("Управление физикой персонажа")

local speedSlider = 16
MoveTab:CreateSlider({
   Name = "Скорость бега (WalkSpeed)",
   Min = 16,
   Max = 45,
   Default = 16,
   Color = Color3.fromRGB(0, 255, 128),
   Increment = 1,
   ValueName = "скорость",
   Callback = function(Value)
      speedSlider = Value
      local char = LocalPlayer.Character
      local hum = char and char:FindFirstChildOfClass("Humanoid")
      if hum then
          hum.WalkSpeed = speedSlider
      end
   end,
})

-- Постоянное поддержание скорости при респавне
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and hum.WalkSpeed ~= speedSlider and speedSlider > 16 then
        hum.WalkSpeed = speedSlider
    end
end)

-- =============================================================================
-- ВКЛАДКА: ВИЗУАЛИЗАЦИЯ (VISUALS / ESP)
-- =============================================================================
local VisualsTab = Window:CreateTab("👁️ Визуальные эффекты", nil)

VisualsTab:CreateSection("Подсветка объектов")

local espEnabled = false
VisualsTab:CreateToggle({
   Name = "Подсветка игроков (ESP)",
   CurrentValue = false,
   Flag = "EspToggle",
   Callback = function(Value)
       espEnabled = Value
       if espEnabled then
           task.spawn(function()
               while espEnabled do
                   for _, p in ipairs(Players:GetPlayers()) do
                       if p ~= LocalPlayer and p.Character then
                           if not p.Character:FindFirstChild("HighlightESP") then
                               local highlight = Instance.new("Highlight")
                               highlight.Name = "HighlightESP"
                               highlight.FillColor = Color3.fromRGB(0, 170, 255)
                               highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                               highlight.FillTransparency = 0.5
                               highlight.Parent = p.Character
                           end
                       end
                   end
                   task.wait(2)
               end
           end)
       else
           for _, p in ipairs(Players:GetPlayers()) do
               if p.Character and p.Character:FindFirstChild("HighlightESP") then
                   p.Character.HighlightESP:Destroy()
               end
           end
       end
   end,
})

Rayfield:Notify({
   Name = "Интерфейс обновлен",
   Content = "Загружены безопасные методы автоматизации.",
   Duration = 5
})
