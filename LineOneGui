local function scanGUI()
    if not CONFIG.SCAN_GUI then return end
    section("GUI — Все интерфейсы")

    local sources = {
        {Services.StarterGui, "StarterGui"},
        {Services.CoreGui,    "CoreGui"},
    }
    -- PlayerGui только если есть LocalPlayer
    if LocalPlayer then
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pg then
            table.insert(sources, 2, {pg, "PlayerGui"})
        end
    end

    for _, src in ipairs(sources) do
        local container, name = src[1], src[2]
        if container then
            subsection(name)
            scanInstance(container, 1, CONFIG.MAX_DEPTH)
        end
    end
end

