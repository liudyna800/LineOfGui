-- ========== ALL PLAYERS ==========
sep("ALL PLAYERS")
for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
    w("[PLAYER] " .. p.Name .. " | UserId:" .. p.UserId .. " | DisplayName:" .. p.DisplayName .. " | AccountAge:" .. p.AccountAge)
    -- leaderstats
    local ls = p:FindFirstChild("leaderstats")
    if ls then
        w("  [leaderstats]")
        for _, s in ipairs(ls:GetChildren()) do
            local v = safeGet(s, "Value")
            w("    " .. s.Name .. " [" .. s.ClassName .. "] = " .. (v or "?"))
        end
    end
    -- все children игрока (stats, значения и т.д.)
    for _, c in ipairs(p:GetChildren()) do
        if c.Name ~= "leaderstats" then
            w("  [" .. c.ClassName .. "] " .. c.Name)
            local v = safeGet(c, "Value")
            if v then w("    Value = " .. v) end
            for _, cc in ipairs(c:GetChildren()) do
                local vv = safeGet(cc, "Value")
                w("    [" .. cc.ClassName .. "] " .. cc.Name .. (vv and (" = "..vv) or ""))
            end
        end
    end
    -- Character
    local char = p.Character
    if char then
        w("  [Character] " .. char.Name)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local pos = safeGet(hrp, "Position")
            if pos then w("    HRP.Position = " .. pos) end
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            w("    Health    = " .. (safeGet(hum,"Health") or "?"))
            w("    MaxHealth = " .. (safeGet(hum,"MaxHealth") or "?"))
            w("    WalkSpeed = " .. (safeGet(hum,"WalkSpeed") or "?"))
            w("    JumpPower = " .. (safeGet(hum,"JumpPower") or "?"))
            w("    DisplayName = " .. (safeGet(hum,"DisplayName") or "?"))
            local anim = hum:FindFirstChildOfClass("Animator")
            if anim then
                local okTr, tracks = pcall(function() return anim:GetPlayingAnimationTracks() end)
                if okTr and tracks and #tracks > 0 then
                    w("    [Playing Animations]")
                    for _, tr in ipairs(tracks) do
                        w("      " .. tr.Name .. " AnimId:" .. tostring(tr.Animation and tr.Animation.AnimationId or "?") .. " Speed:" .. tostring(tr.Speed))
                    end
                end
            end
        end
        -- Все части персонажа
        for _, part in ipairs(char:GetChildren()) do
            w("    [" .. part.ClassName .. "] " .. part.Name)
        end
    end
    -- Backpack
    local bp = p:FindFirstChildOfClass("Backpack")
    if bp then
        local tools = bp:GetChildren()
        w("  [Backpack] tools:" .. #tools)
        for _, t2 in ipairs(tools) do
            w("    [" .. t2.ClassName .. "] " .. t2.Name .. " | ToolTip:" .. (safeGet(t2,"ToolTip") or ""))
        end
    end
    -- PlayerGui (только наш)
    if p == lp then
        local pg = p:FindFirstChildOfClass("PlayerGui")
        if pg then
            w("  [PlayerGui]")
            scan(pg, 2, 0)
        end
    end
    w("")
end

-- ========== REMOTES (полный поиск) ==========
sep("ALL REMOTES")
local remoteClasses = {RemoteEvent=true,RemoteFunction=true,BindableEvent=true,BindableFunction=true,UnreliableRemoteEvent=true}
local function findRemotes(parent, list)
    local ok, ch = pcall(function() return parent:GetChildren() end)
    if not ok then return end
    for _, c in ipairs(ch) do
        if remoteClasses[c.ClassName] then
            local okFP, fp = pcall(function() return c:GetFullName() end)
            table.insert(list, {name=c.Name, class=c.ClassName, path=okFP and fp or c.Name})
        end
        findRemotes(c, list)
    end
end
local allRemotes = {}
findRemotes(game, allRemotes)
w("Total remotes found: " .. #allRemotes)
w("")
for _, r in ipairs(allRemotes) do
    w("[" .. r.class .. "] " .. r.name)
    w("  Path: " .. r.path)
    if r.class == "RemoteEvent" then
        w("  FireServer:    " .. r.path .. ":FireServer(...)")
        w("  OnClientEvent: " .. r.path .. ".OnClientEvent:Connect(function(...) print(...) end)")
    elseif r.class == "RemoteFunction" then
        w("  InvokeServer:  " .. r.path .. ":InvokeServer(...)")
    elseif r.class == "BindableEvent" then
        w("  Fire:          " .. r.path .. ":Fire(...)")
        w("  Event:         " .. r.path .. ".Event:Connect(function(...) print(...) end)")
    end
    w("")
end

