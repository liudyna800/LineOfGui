            Instance.new("UICorner", button).CornerRadius = UDim.new(0, 4)
            
            button.MouseButton1Click:Connect(function()
                if #args > 0 then
                    callback(table.unpack(args))
                else
                    callback()
                end
            end)
            
            contentFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + UIPadding.PaddingTop.Offset + 8)
