-- ═══════════════════════════════════════════
--           ГЛАВНАЯ ФУНКЦИЯ
-- ═══════════════════════════════════════════
local function runExplorer()
    writeln("================================================================")
    writeln("  DELTA EXPLORER v2.1 (bugfixed) — Script Scanner Output")
    writeln("================================================================")
    writeln("Scan time    : " .. tostring(os.date and os.date("%Y-%m-%d %H:%M:%S") or tick()))
    writeln("PlaceId      : " .. game.PlaceId)
    writeln("JobId        : " .. game.JobId)
    writeln("PlaceVersion : " .. game.PlaceVersion)
    writeln("")

    scanGameInfo()
    scanPlayers()
    scanRemotes()
    scanScripts()
    scanWorkspace()
    scanReplicated()
    scanGUI()
    scanTools()
    scanLighting()
    scanTeams()
    generateScriptTemplate()
    printStats()

    writeln("")
    writeln("================================================================")
    writeln("  SKANIROVANIE ZAVERSHENO")
    writeln("================================================================")

    local finalOutput = table.concat(output)
    local fileName = getUniqueFileName()
    local saved = false

    -- Метод 1: writefile
    if writefile then
        local ok, err = pcall(function() writefile(fileName, finalOutput) end)
        if ok then
            saved = true
            print("[DeltaExplorer] File saved: " .. fileName)
        else
            warn("[DeltaExplorer] writefile error: " .. tostring(err))
        end
    end

    -- Метод 2: clipboard fallback
    if not saved then
        if setclipboard then
            pcall(function() setclipboard(finalOutput) end)
            print("[DeltaExplorer] writefile unavailable — data copied to clipboard!")
        else
            print("[DeltaExplorer] No writefile/setclipboard. Printing to console...")
            print(finalOutput)
        end
    end

    print("-------------------------------------------")
    print("[DeltaExplorer] Done!")
    print("  File     : " .. fileName)
    print("  Objects  : " .. scanStats.total)
    print("  Remotes  : " .. scanStats.remotes)
    print("  Scripts  : " .. scanStats.scripts)
    print("  Players  : " .. scanStats.players)
    print("-------------------------------------------")

    return fileName
end

-- ═══════════════════════════════════════════
--              ЗАПУСК
-- ═══════════════════════════════════════════
print("[DeltaExplorer] Starting scan...")
local success, err = pcall(runExplorer)
if not success then
    warn("[DeltaExplorer] FATAL ERROR: " .. tostring(err))
end
