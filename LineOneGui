    local jobRaw   = tostring(game.JobId)
    local jobId    = (#jobRaw >= 8) and jobRaw:sub(1, 8) or (jobRaw ~= "" and jobRaw or "studio")
    local tick_str = tostring(math.floor(tick())):sub(-6)
    return string.format("%s_%s_%s_%s.txt", CONFIG.FILE_PREFIX, placeId, jobId, tick_str)
end

-- Безопасное получение свойства объекта
local function safeGet(obj, prop)
    local ok, val = pcall(function() return obj[prop] end)
    if not ok or val == nil then return nil end
    local t = typeof(val)
    if t == "Instance" then
        local okPath, fullName = pcall(function() return val:GetFullName() end)
        return "[Instance: " .. val.ClassName .. "] " .. (okPath and fullName or "?")
    elseif t == "CFrame" then
        return string.format("CFrame(%.2f, %.2f, %.2f)", val.X, val.Y, val.Z)
    elseif t == "Vector3" then
        return string.format("Vector3(%.2f, %.2f, %.2f)", val.X, val.Y, val.Z)
    elseif t == "Vector2" then
        return string.format("Vector2(%.2f, %.2f)", val.X, val.Y)
    elseif t == "Color3" then
        return string.format("Color3(%.2f, %.2f, %.2f)", val.R, val.G, val.B)
    elseif t == "UDim2" then
        return string.format("UDim2({%.2f,%d},{%.2f,%d})", val.X.Scale, val.X.Offset, val.Y.Scale, val.Y.Offset)
    elseif t == "EnumItem" then
        return tostring(val)
    elseif t == "boolean" or t == "number" or t == "string" then
        return tostring(val)
    else
        return "[" .. t .. "]"
    end
end

local function writeln(str)
    table.insert(output, (str or "") .. "\n")
end

local function section(title)
    writeln("")
    writeln("╔══════════════════════════════════════════════════════════════╗")
    -- БАГ #4 ИСПРАВЛЕН: #title считал байты, а не символы — кириллица
    -- занимает 2 байта, из-за чего рамка съезжала. Теперь длина
    -- вычисляется через utf8.len() с fallback на байтовую длину.
    local titleLen = utf8 and utf8.len(title) or #title
    writeln("║  " .. title .. string.rep(" ", math.max(0, 59 - titleLen)) .. "║")
    writeln("╚══════════════════════════════════════════════════════════════╝")
end

local function subsection(title)
    writeln("")
    local titleLen = utf8 and utf8.len(title) or #title
    writeln("  ┌─── " .. title .. " " .. string.rep("─", math.max(0, 53 - titleLen)))
end

local function indent(depth)
    return string.rep("  ", depth)
end

