-- ========== SCRIPTS (все) ==========
sep("ALL SCRIPTS")
local scriptClasses = {Script=true, LocalScript=true, ModuleScript=true}
local function findScripts(parent, list)
    local ok, ch = pcall(function() return parent:GetChildren() end)
    if not ok then return end
    for _, c in ipairs(ch) do
        if scriptClasses[c.ClassName] then
            local okFP, fp = pcall(function() return c:GetFullName() end)
            local dis = safeGet(c, "Disabled")
            table.insert(list, {name=c.Name, class=c.ClassName, path=okFP and fp or c.Name, disabled=dis})
        end
        findScripts(c, list)
    end
end
local allScripts = {}
findScripts(game, allScripts)
w("Total scripts: " .. #allScripts)
w("")
for _, s in ipairs(allScripts) do
    w("[" .. s.class .. "] " .. s.name .. " | " .. s.path .. (s.disabled == "true" and " [DISABLED]" or ""))
end

