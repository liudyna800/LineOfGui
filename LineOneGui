local function getProperties(obj, depth)
    if not CONFIG.INCLUDE_PROPERTIES then return end
    local props = PROPERTIES_BY_CLASS[obj.ClassName]
    if props and #props > 0 then
        for _, prop in ipairs(props) do
            local val = safeGet(obj, prop)
            if val then
                writeln(indent(depth) .. "  > " .. prop .. " = " .. val)
            end
        end
    end
end

