local REMOTE_CLASSES = {
    RemoteEvent=true, RemoteFunction=true,
    BindableEvent=true, BindableFunction=true,
    UnreliableRemoteEvent=true,
}
local SCRIPT_CLASSES  = {Script=true, LocalScript=true, ModuleScript=true}
local GUI_CLASSES     = {
    ScreenGui=true, SurfaceGui=true, BillboardGui=true,
    Frame=true, TextLabel=true, TextButton=true,
    TextBox=true, ImageLabel=true, ImageButton=true, ScrollingFrame=true,
}
local VALUE_CLASSES   = {
    NumberValue=true, StringValue=true, BoolValue=true,
    IntValue=true, ObjectValue=true, Color3Value=true,
    Vector3Value=true, CFrameValue=true, NumberConstrainedValue=true,
}

-- БАГ #5 ИСПРАВЛЕН: childCount вычислялся через #child:GetChildren() без
-- pcall — в некоторых играх это бросает ошибку на закрытых объектах.
local function safeChildCount(obj)
    local ok, children = pcall(function() return obj:GetChildren() end)
    return ok and #children or 0
end

local function scanInstance(obj, depth, maxDepth)
    if maxDepth ~= 0 and depth > maxDepth then return end
    local ok, children = pcall(function() return obj:GetChildren() end)
    if not ok then return end

    for _, child in ipairs(children) do
        local className  = child.ClassName
        local name       = child.Name
        local childCount = safeChildCount(child)

        local icon = "+-"
        if REMOTE_CLASSES[className] then
            icon = "[REMOTE]"
            scanStats.remotes = scanStats.remotes + 1
        elseif SCRIPT_CLASSES[className] then
            icon = "[SCRIPT]"
            scanStats.scripts = scanStats.scripts + 1
        elseif GUI_CLASSES[className] then
            icon = "[GUI]"
            scanStats.guis = scanStats.guis + 1
        elseif VALUE_CLASSES[className] then
            icon = "[VALUE]"
            scanStats.values = scanStats.values + 1
        elseif className == "Tool" then
            icon = "[TOOL]"
            scanStats.tools = scanStats.tools + 1
        elseif className == "Animation" then
            icon = "[ANIM]"
            scanStats.animations = scanStats.animations + 1
        elseif className == "Sound" then
            icon = "[SND]"
        elseif className == "ProximityPrompt" then
            icon = "[PROMPT]"
        elseif className == "Humanoid" then
            icon = "[HUM]"
        end

        scanStats.total = scanStats.total + 1

        -- БАГ #6 ИСПРАВЛЕН: path вычислялся через GetFullName() без pcall.
        -- Если объект уже удалён во время итерации — крашится весь сканер.
        local path = name
        if CONFIG.INCLUDE_FULL_PATH then
            local okP, fp = pcall(function() return child:GetFullName() end)
            path = okP and fp or (name .. " [path error]")
        end

        local line = indent(depth) .. icon .. " [" .. className .. "] " .. name
        if CONFIG.INCLUDE_FULL_PATH then
            line = line .. "  ->  " .. path
        end
        if CONFIG.INCLUDE_CHILDREN_COUNT and childCount > 0 then
            line = line .. "  (" .. childCount .. " ch)"
        end
        writeln(line)

        getProperties(child, depth + 1)
        getAttributes(child, depth + 1)

        if childCount > 0 then
            scanInstance(child, depth + 1, maxDepth)
        end
    end
end

