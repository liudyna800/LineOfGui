            label.Font = Enum.Font.Gotham
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = toggleFrame
            
            local toggle = Instance.new("Frame")
            toggle.Size = UDim2.new(0, 38, 0, 20)
            toggle.Position = UDim2.new(1, -48, 0.5, -10)
            toggle.BackgroundColor3 = Color3.fromRGB(55, 55, 60)
            toggle.Parent = toggleFrame
            
            Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 10)
            
            local toggleDot = Instance.new("Frame")
            toggleDot.Size = UDim2.new(0, 16, 0, 16)
            toggleDot.Position = UDim2.new(0, 2, 0.5, -8)
            toggleDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            toggleDot.Parent = toggle
            
            Instance.new("UICorner", toggleDot).CornerRadius = UDim.new(0, 8)
            
            local tweenService = game:GetService("TweenService")
            local enabled = false
            
            toggleFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    enabled = not enabled
                    if enabled then
                        toggle.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
                        tweenService:Create(toggleDot, TweenInfo.new(0.15), {Position = UDim2.new(1, -18, 0.5, -8)}):Play()
                    else
                        toggle.BackgroundColor3 = Color3.fromRGB(55, 55, 60)
                        tweenService:Create(toggleDot, TweenInfo.new(0.15), {Position = UDim2.new(0, 2, 0.5, -8)}):Play()
                    end
                    callback(enabled)
                end
            end)
            
            contentFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + UIPadding.PaddingTop.Offset + 8)
            UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                contentFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + UIPadding.PaddingTop.Offset + 8)
            end)
            
            local toggleObj = {
                Enabled = false,
                GetPropertyChangedSignal = function() return nil end,
                Destroy = function() toggleFrame:Destroy() end
            }
            
            local mt = {
                __index = function(t, k)
                    if k == "Enabled" then return enabled end
                end,
                __newindex = function(t, k, v)
                    if k == "Enabled" then
                        enabled = v
                        if v then
                            toggle.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
                            tweenService:Create(toggleDot, TweenInfo.new(0.15), {Position = UDim2.new(1, -18, 0.5, -8)}):Play()
                        else
                            toggle.BackgroundColor3 = Color3.fromRGB(55, 55, 60)
                            tweenService:Create(toggleDot, TweenInfo.new(0.15), {Position = UDim2.new(0, 2, 0.5, -8)}):Play()
                        end
                    end
                end
            }
            setmetatable(toggleObj, mt)
            
            return toggleObj
        end
        
        return tabMethods
    end
    
